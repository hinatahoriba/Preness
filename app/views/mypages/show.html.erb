<main class="flex-grow max-w-4xl w-full mx-auto px-4 md:px-6 py-8 md:py-12 space-y-8 animate-fadeInUp">
  <%# 挨拶メッセージ %>
  <div class="px-2">
    <h2 class="text-xl md:text-2xl font-black text-brand-navy tracking-tight">
      こんにちは、<%= current_user.user_profile&.nickname || "ゲスト" %>さん！
    </h2>
    <p class="text-xs text-gray-400 mt-1">スコアアップを目指して、今日も効率よく学習しましょう。</p>
  </div>

  <%# 模擬試験セクション %>
  <section class="bg-brand-teal-light rounded-[32px] p-6 lg:p-10 shadow-sm border border-brand-teal/10 flex flex-col items-center justify-between gap-8">
    <div class="flex flex-col md:flex-row items-center gap-6 w-full">
      <div class="w-14 h-14 rounded-2xl bg-white text-brand-teal flex items-center justify-center shrink-0 shadow-sm border border-brand-teal/5">
        <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
        </svg>
      </div>
      <div class="space-y-1 text-center md:text-left flex-1">
        <h1 class="text-2xl md:text-[26px] font-black text-brand-navy tracking-tighter">模擬試験</h1>
        <p class="text-brand-teal/60 font-medium text-xs leading-relaxed max-w-md mx-auto md:mx-0">
          現在の推定スコアを精密に算出。<br class="hidden md:block">
          回答記録をもとにAIが分析します。
        </p>
      </div>
      <div class="flex flex-col sm:flex-row gap-3 w-full md:w-auto shrink-0">
        <% if @diagnostic %>
          <%= link_to guideline_diagnostic_path(@diagnostic), class: "flex-1 px-8 py-4 bg-brand-orange-btn text-white rounded-2xl font-black text-sm flex items-center justify-center gap-2 hover:opacity-90 hover:scale-[1.02] active:scale-95 transition-all shadow-lg shadow-orange-500/20 whitespace-nowrap" do %>
            無料実力診断
          <% end %>
        <% end %>
        <%= link_to mocks_path, class: "flex-1 px-8 py-4 bg-brand-teal text-white rounded-2xl font-black text-sm flex items-center justify-center gap-2 hover:opacity-90 hover:scale-[1.02] active:scale-95 transition-all shadow-lg shadow-teal-500/20 whitespace-nowrap group" do %>
          試験を受験する
          <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        <% end %>
      </div>
    </div>
  </section>

  <%# セクション別演習セクション %>
  <section class="bg-brand-teal-light rounded-[32px] p-6 lg:p-10 shadow-sm border border-brand-teal/10 flex flex-col items-center justify-between gap-8">
    <div class="flex flex-col md:flex-row items-center gap-6 w-full">
      <div class="w-14 h-14 rounded-2xl bg-white text-brand-teal flex items-center justify-center shrink-0 shadow-sm border border-brand-teal/5">
        <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
        </svg>
      </div>
      <div class="space-y-1 text-center md:text-left flex-1">
        <h2 class="text-2xl md:text-[26px] font-black text-brand-navy tracking-tighter">セクション別演習</h2>
        <p class="text-brand-teal/60 font-medium text-xs leading-relaxed max-w-md mx-auto md:mx-0">
          LISTENING、GRAMMAR、READINGの各分野を<br class="hidden md:block">
          自分のペースで集中的にトレーニングします。
        </p>
      </div>
      <div class="flex flex-col sm:flex-row gap-3 w-full md:w-auto shrink-0">
        <%= link_to exercises_path, class: "flex-1 px-8 py-4 bg-brand-teal text-white rounded-2xl font-black text-sm flex items-center justify-center gap-2 hover:opacity-90 hover:scale-[1.02] active:scale-95 transition-all shadow-lg shadow-teal-500/20 whitespace-nowrap group" do %>
          演習を始める
          <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        <% end %>
      </div>
    </div>
  </section>

  <%# コミュニティセクション %>
  <section class="pt-2">
    <div class="relative rounded-[40px] overflow-hidden min-h-[220px] md:min-h-[180px] flex items-center group cursor-pointer shadow-sm">
      <div class="absolute inset-0">
        <img src="https://images.unsplash.com/photo-1517486808906-6ca8b3f04846?q=80&w=2098&auto=format&fit=crop" alt="Community Life" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110">
        <div class="absolute inset-0 bg-gradient-to-r from-brand-navy/95 via-brand-navy/80 to-transparent"></div>
      </div>

      <div class="relative z-10 w-full p-6 md:p-10 flex flex-col md:flex-row items-center justify-between gap-6">
        <div class="flex items-center gap-5 w-full md:w-auto text-center md:text-left">
          <div class="space-y-3 w-full">
            <h2 class="text-2xl md:text-3xl font-black text-white tracking-tight">Preness Community</h2>
            <div class="flex flex-wrap justify-center md:justify-start gap-x-5 gap-y-2">
              <div class="flex items-center gap-1.5">
                <svg class="w-4 h-4 text-brand-orange" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
                </svg>
                <span class="text-[11px] md:text-xs font-bold text-white/90">仲間との交流</span>
              </div>
              <div class="flex items-center gap-1.5">
                <svg class="w-4 h-4 text-brand-orange" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <span class="text-[11px] md:text-xs font-bold text-white/90">ワーホリ/語学留学支援</span>
              </div>
              <div class="flex items-center gap-1.5">
                <svg class="w-4 h-4 text-brand-orange" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
                <span class="text-[11px] md:text-xs font-bold text-white/90">就活サポート</span>
              </div>
            </div>
          </div>
        </div>

        <%= link_to "https://lin.ee/sCMNSBS", class: "w-full md:w-auto px-8 py-4 bg-white text-brand-navy rounded-2xl font-black text-sm flex items-center justify-center gap-2 hover:bg-brand-orange hover:text-white transition-all shadow-xl active:scale-95 group/btn whitespace-nowrap", target: "_blank", rel: "noopener noreferrer" do %>
          今すぐ参加する
          <svg class="w-4 h-4 transition-transform group-hover/btn:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        <% end %>
      </div>
    </div>
  </section>
</main>
