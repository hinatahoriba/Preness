<% content_for :body_class, "bg-[#f9fafb] text-[#374151] h-screen" %>

<div class="flex h-full">
  <%# サイドバー %>
  <aside class="w-60 bg-white border-r border-gray-100 flex flex-col h-full">
    <div class="p-6">
      <h1 class="text-xl font-black italic text-gray-800 tracking-tighter text-center">Preness</h1>
    </div>

    <nav class="flex-1 px-3 space-y-1">
      <%= link_to mypage_path, class: "flex items-center space-x-3 bg-blue-50 text-blue-600 px-4 py-2.5 rounded-xl font-bold" do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"></path></svg>
        <span class="text-sm">ダッシュボード</span>
      <% end %>
<%# 模擬試験へのリンクは削除 %>

      <%= link_to "#", class: "flex items-center space-x-3 text-gray-400 hover:bg-gray-50 px-4 py-2.5 rounded-xl font-medium transition" do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
        <span class="text-sm">学習履歴</span>
      <% end %>
      <%= link_to account_setting_path, class: "flex items-center space-x-3 text-gray-400 hover:bg-gray-50 px-4 py-2.5 rounded-xl font-medium transition" do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
        <span class="text-sm">アカウント設定</span>
      <% end %>

      <%= link_to "#", class: "flex items-center space-x-3 text-gray-400 hover:bg-gray-50 px-4 py-2.5 rounded-xl font-medium transition" do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
        <span class="text-sm">サポート・規約</span>
      <% end %>
    </nav>

    <div class="p-6 border-t border-gray-50">
      <%= link_to destroy_user_session_path, data: { turbo_method: :delete }, class: "flex items-center space-x-3 text-gray-400 hover:text-red-500 transition text-sm font-medium w-full px-4" do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path></svg>
        <span>ログアウト</span>
      <% end %>
    </div>
  </aside>

  <%# メインコンテンツ %>
  <main class="flex-1 p-8 flex flex-col justify-between overflow-hidden">
    <header class="flex justify-between items-center mb-6">
      <div>
        <h2 class="text-xl font-bold tracking-tight text-gray-900 leading-none">こんにちは！</h2>
        <p class="text-gray-400 text-xs mt-1.5">スコアアップを目指して、今日も効率よく学習しましょう。</p>
      </div>
    </header>

    <div class="mb-6 flex-shrink-0">
      <div class="flex items-center space-x-2 mb-4 border-l-4 border-[#2d9a9e] pl-3">
        <h3 class="font-bold text-lg text-gray-800">TOEFL ITP</h3>
      </div>

      <div class="grid grid-cols-2 gap-6">
        <%# セクション別演習カード %>
        <div class="bg-white border border-gray-100 rounded-2xl overflow-hidden shadow-sm flex flex-col">
          <div class="py-10 flex justify-center bg-[#fcfdfe]">
            <div class="w-12 h-12 bg-teal-50 rounded-full flex items-center justify-center text-[#34a0a4]">
              <svg class="w-6 h-6 ml-0.5" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
            </div>
          </div>
          <div class="p-4 bg-white border-t border-gray-50 flex flex-col items-center">
            <p class="text-xs font-bold mb-3 text-gray-500">セクション別演習</p>
            <%= link_to exercises_path, class: "w-full bg-[#34a0a4] hover:bg-[#2d8b8e] text-white py-3 rounded-xl text-sm font-bold flex items-center justify-center space-x-2 transition shadow-sm" do %>
              <span>演習へ進む</span>
              <span>→</span>
            <% end %>
          </div>
        </div>

        <%# 模擬試験カード %>
        <div class="bg-white border border-gray-100 rounded-2xl overflow-hidden shadow-sm flex flex-col">
          <div class="py-10 flex justify-center bg-[#fcfdfe]">
            <div class="w-12 h-12 bg-white rounded-xl flex items-center justify-center text-gray-300 border border-gray-100 shadow-sm">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
            </div>
          </div>
          <div class="p-4 bg-white border-t border-gray-50 flex flex-col items-center">
            <p class="text-xs font-bold mb-3 text-gray-500">模擬試験</p>
            <%= link_to mocks_path, class: "w-full bg-[#34a0a4] hover:bg-[#2d8b8e] text-white py-3 rounded-xl text-sm font-bold flex items-center justify-center space-x-2 transition shadow-sm" do %>
              <span>試験を受験する</span>
              <span>→</span>
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <%# コミュニティバナー %>
    <div class="flex-1 min-h-[280px]">
      <div class="relative w-full h-full rounded-[24px] overflow-hidden shadow-lg group">
        <img src="https://images.unsplash.com/photo-1522202176988-66273c2fd55f?auto=format&fit=crop&q=80&w=1400"
             alt="Community"
             class="absolute inset-0 w-full h-full object-cover">

        <div class="absolute inset-0 bg-gradient-to-r from-black/80 via-black/50 to-transparent flex flex-col justify-center px-10 text-white">
          <div class="max-w-xl">
            <div class="flex items-center space-x-2 mb-3 border-l-4 border-[#34a0a4] pl-4">
              <h3 class="text-lg font-bold tracking-tight leading-none">Prenessコミュニティ</h3>
            </div>

            <p class="text-sm font-bold mb-3 text-gray-100 leading-relaxed">
              TOEFL対策だけで終わらない、留学・就活まで見据えたコミュニティ。
            </p>

            <div class="space-y-2 text-xs text-gray-300 leading-relaxed opacity-90 hidden md:block">
              <p>オンラインセミナーや個別面談を通じて、次のステップを具体的に描くことができます。留学経験者への相談も可能です。</p>
            </div>

            <%= link_to "#", class: "mt-5 bg-[#34a0a4] hover:bg-[#2d8b8e] text-white px-6 py-2.5 rounded-xl text-xs font-bold flex items-center space-x-2 transition-all active:scale-95 w-fit" do %>
              <span>コミュニティに進む</span>
              <span>→</span>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </main>
</div>
