<% section_type = local_assigns.fetch(:section_type, nil) %>

<% questions.each_with_index do |question, index| %>
  <% selected_choice = answers_by_question_id[question.id]&.selected_choice %>
  <% is_skipped = answers_by_question_id[question.id]&.skipped? %>

  <div class="p-5 border border-gray-200 rounded-sm bg-white shadow-sm font-sans mb-4 last:mb-0">
    <div class="flex items-center mb-3">
      <span class="text-[#0f2361] font-semibold text-base mr-3">#<%= index + 1 %></span>

      <div class="min-w-0 flex-1">
        <% if section_type == "listening" %>
          <p class="sr-only"><%= question.question_text %></p>
          <% if question.audio_url.present? %>
            <audio class="w-full" controls src="<%= question.audio_url %>"></audio>
          <% end %>
        <% else %>
          <h2 class="text-lg font-semibold text-gray-800"><%= question.question_text %></h2>

          <% if question.audio_url.present? %>
            <audio class="mt-3 w-full" controls src="<%= question.audio_url %>"></audio>
          <% end %>
        <% end %>
      </div>
    </div>

    <div class="space-y-2">
      <% Question::CHOICES.each do |choice| %>
        <% input_id = "exercise_question_#{question.id}_#{choice}" %>
        <label
          for="<%= input_id %>"
          class="group flex items-center p-3 border rounded-sm cursor-pointer transition-colors bg-white hover:bg-gray-50 border-gray-200 has-[:checked]:border-2 has-[:checked]:border-[#0f2361] has-[:checked]:bg-white has-[:checked]:hover:bg-white"
        >
          <input
            class="sr-only"
            type="radio"
            id="<%= input_id %>"
            name="answers[<%= question.id %>]"
            value="<%= choice %>"
            <%= "checked" if selected_choice == choice %>
            data-action="exercise-progress#update"
          />
          <div class="flex items-center justify-center w-9 h-9 rounded-sm border border-gray-300 text-gray-500 font-medium text-sm mr-3 flex-shrink-0 group-has-[:checked]:bg-[#0f2361] group-has-[:checked]:text-white group-has-[:checked]:border-transparent">
            <%= choice %>
          </div>
          <span class="text-gray-800 text-sm group-has-[:checked]:text-gray-900 group-has-[:checked]:font-medium whitespace-pre-line leading-relaxed"><%= question_choice_text(question, choice) %></span>
        </label>
      <% end %>

      <% skip_input_id = "exercise_question_#{question.id}_skip" %>
      <label
        for="<%= skip_input_id %>"
        class="group flex items-center p-3 border rounded-sm cursor-pointer transition-colors bg-white hover:bg-gray-50 border-gray-200 has-[:checked]:border-2 has-[:checked]:border-gray-400 has-[:checked]:bg-gray-50 has-[:checked]:hover:bg-gray-50"
      >
        <input
          class="sr-only"
          type="radio"
          id="<%= skip_input_id %>"
          name="answers[<%= question.id %>]"
          value="skip"
          <%= "checked" if is_skipped %>
          data-action="exercise-progress#update"
        />
        <div class="flex items-center justify-center w-9 h-9 rounded-sm border border-gray-300 text-gray-400 font-medium text-sm mr-3 flex-shrink-0 group-has-[:checked]:bg-gray-400 group-has-[:checked]:text-white group-has-[:checked]:border-transparent">
          ?
        </div>
        <span class="text-gray-400 text-sm group-has-[:checked]:text-gray-600 group-has-[:checked]:font-medium">わからない</span>
      </label>
    </div>
  </div>
<% end %>
