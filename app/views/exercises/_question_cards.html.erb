<% section_type = local_assigns.fetch(:section_type, nil) %>

<% questions.each_with_index do |question, index| %>
  <% selected_choice = answers_by_question_id[question.id]&.selected_choice %>

  <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
    <div class="flex items-start gap-4">
      <span class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-orange-100 text-sm font-bold text-orange-700">
        Q<%= index + 1 %>
      </span>

      <div class="min-w-0 flex-1">
        <% if section_type == "listening" %>
          <p class="sr-only"><%= question.question_text %></p>
          <% if question.audio_url.present? %>
            <audio class="w-full" controls src="<%= question.audio_url %>"></audio>
          <% end %>
        <% else %>
          <p class="text-sm font-semibold leading-relaxed text-slate-900"><%= question.question_text %></p>

          <% if question.audio_url.present? %>
            <audio class="mt-4 w-full" controls src="<%= question.audio_url %>"></audio>
          <% end %>
        <% end %>

        <div class="mt-5 grid gap-3">
          <% Question::CHOICES.each do |choice| %>
            <% input_id = "exercise_question_#{question.id}_#{choice}" %>
            <div>
              <input
                class="peer sr-only"
                type="radio"
                id="<%= input_id %>"
                name="answers[<%= question.id %>]"
                value="<%= choice %>"
                <%= "checked" if selected_choice == choice %>
                data-action="exercise-progress#update"
              />
              <label
                for="<%= input_id %>"
                class="flex cursor-pointer items-start gap-3 rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-700 shadow-sm transition hover:bg-slate-50 peer-checked:border-orange-400 peer-checked:bg-orange-50"
              >
                <span class="mt-0.5 inline-flex h-6 w-6 shrink-0 items-center justify-center rounded-full border border-slate-300 text-xs font-bold text-slate-600">
                  <%= choice %>
                </span>
                <span class="whitespace-pre-line leading-relaxed"><%= question_choice_text(question, choice) %></span>
              </label>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
<% end %>
