<% set_title = exercise_set_title(section_type: @section.section_type, part_type: @part.part_type, set_number: @question_set.display_order) %>
<% is_reading = @section.section_type == "reading" %>
<% form_id = "exercise-answer-form" %>

<div
  class="<%= is_reading ? 'h-screen flex flex-col overflow-hidden' : 'min-h-screen' %> bg-[#f4f5f7]"
  data-controller="exercise-progress"
  data-exercise-progress-total-count-value="<%= @total_count %>"
>
  <%# ===== Header ===== %>
  <header class="sticky top-0 z-50 flex items-stretch bg-[#001c54] h-16 shadow-sm">
    <%# Left: title %>
    <div class="flex items-center px-6 border-r border-[#ffffff20] whitespace-nowrap">
      <h1 class="text-[13px] font-bold text-white tracking-wide uppercase">
        <%= set_title %>
      </h1>
    </div>

    <%# Center: progress indicator %>
    <div class="flex-1 flex flex-col items-center justify-center px-4">
      <span class="text-xs font-bold text-white tracking-widest mb-1">
        回答済み :
        <span data-exercise-progress-target="answeredCount"><%= @answered_count %></span>/<%= @total_count %>問
      </span>
      <div class="flex flex-wrap justify-center gap-[3px]">
        <% @questions.each do |question| %>
          <div
            class="w-[10px] h-[3px] bg-white/30"
            data-exercise-progress-target="indicator"
            data-question-id="<%= question.id %>"
          ></div>
        <% end %>
      </div>
    </div>

    <%# Right: nav + submit %>
    <div class="flex items-center gap-3 px-6 border-l border-[#ffffff20] whitespace-nowrap">
      <%= link_to "一覧に戻る", exercises_path,
            class: "px-5 py-2 bg-white border border-gray-300 text-gray-800 text-[12px] font-bold rounded-sm hover:bg-gray-50 transition-colors" %>
      <% if @attempt.present? %>
        <%= link_to "結果履歴を見る", history_exercise_path(@exercise),
              class: "px-5 py-2 bg-white border border-gray-300 text-gray-800 text-[12px] font-bold rounded-sm hover:bg-gray-50 transition-colors" %>
      <% end %>
      <%= button_tag "採点する",
            type: :submit,
            form: form_id,
            disabled: true,
            data: { "exercise-progress-target": "submitButton" },
            class: "px-6 py-2 bg-white text-[#001c54] text-[12px] font-bold rounded-sm hover:bg-gray-50 disabled:opacity-40 disabled:cursor-not-allowed transition-colors cursor-pointer" %>
    </div>
  </header>

  <%# ===== Form + Content ===== %>
  <%= form_with url: answer_exercise_path(@exercise), method: :post, id: form_id,
        class: is_reading ? "flex-1 flex flex-col overflow-hidden" : "" do %>
    <% if @section.section_type == "listening" && @part.part_type == "part_a" %>
      <%= render "exercises/listening_part_a", questions: @questions %>

    <% elsif @section.section_type == "listening" %>
      <%= render "exercises/listening_part_bc",
            question_set: @question_set,
            part_label: exercise_part_label(@part.part_type)&.upcase %>

    <% elsif @section.section_type == "structure" %>
      <%= render "exercises/structure", questions: @questions %>

    <% elsif @section.section_type == "reading" %>
      <%= render "exercises/reading", question_set: @question_set %>
    <% end %>
  <% end %>
</div>
