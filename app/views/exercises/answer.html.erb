<% set_title = exercise_set_title(section_type: @section.section_type, part_type: @part.part_type, set_number: @question_set.display_order) %>
<% is_reading = @section.section_type == "reading" %>
<% form_id = "exercise-answer-form" %>

<div
  class="<%= is_reading ? 'h-screen flex flex-col overflow-hidden' : 'min-h-screen' %> bg-white"
  data-controller="exercise-progress"
  data-exercise-progress-total-count-value="<%= @total_count %>"
>
  <%# ===== Header ===== %>
  <header class="flex-shrink-0 flex items-stretch h-16 border-b-[3px] border-[#1a1b4b] bg-white sticky top-0 z-50 font-sans">
    <%# Left: title %>
    <div class="flex items-center gap-4 px-6 w-1/3 min-w-0">
      <h1 class="text-[11px] font-bold tracking-[0.12em] text-gray-800 uppercase whitespace-nowrap truncate font-serif">
        <%= set_title %>
      </h1>
    </div>

    <%# Center: progress indicator %>
    <div class="flex flex-col items-center justify-center border-l border-r border-gray-200 w-1/3 px-4">
      <div class="text-xs text-gray-600 mb-1">
        回答済み :
        <span class="text-gray-800 font-medium" data-exercise-progress-target="answeredCount"><%= @answered_count %></span>/<%= @total_count %>問
      </div>
      <div class="flex flex-wrap justify-center gap-1 w-full max-w-[250px]">
        <% @questions.each do |question| %>
          <div
            class="w-3 h-1 bg-gray-300"
            data-exercise-progress-target="indicator"
            data-question-id="<%= question.id %>"
          ></div>
        <% end %>
      </div>
    </div>

    <%# Right: nav + submit %>
    <div class="flex items-center justify-end px-6 gap-4 w-1/3 text-sm">
      <div class="flex gap-2">
        <%= link_to "一覧に戻る", exercises_path,
              class: "px-5 py-2 border border-gray-300 hover:bg-gray-50 transition-colors text-gray-700" %>
        <% if @attempt.present? %>
          <%= link_to "結果履歴を見る", history_exercise_path(@exercise),
                class: "px-5 py-2 border border-gray-300 hover:bg-gray-50 transition-colors text-gray-700" %>
        <% end %>
      </div>
      <%= button_tag "採点する",
            type: :submit,
            form: form_id,
            disabled: true,
            data: { "exercise-progress-target": "submitButton" },
            class: "px-8 py-2 bg-[#1a1b4b] text-white hover:bg-blue-900 transition-colors disabled:opacity-40 disabled:cursor-not-allowed cursor-pointer whitespace-nowrap" %>
    </div>
  </header>

  <%# ===== Form + Content ===== %>
  <%= form_with url: answer_exercise_path(@exercise), method: :post, id: form_id,
        class: is_reading ? "flex-1 flex flex-col overflow-hidden" : "" do %>
    <% if @section.section_type == "listening" && @part.part_type == "part_a" %>
      <%= render "exercises/listening_part_a", questions: @questions %>

    <% elsif @section.section_type == "listening" %>
      <%= render "exercises/listening_part_bc",
            question_set: @question_set,
            part_label: exercise_part_label(@part.part_type)&.upcase %>

    <% elsif @section.section_type == "structure" %>
      <%= render "exercises/structure", questions: @questions, part_label: exercise_part_label(@part.part_type)&.upcase %>

    <% elsif @section.section_type == "reading" %>
      <%= render "exercises/reading", question_set: @question_set %>
    <% end %>
  <% end %>
</div>
