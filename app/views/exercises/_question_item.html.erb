<%# Locals:
#   question (Question) – question record
#   index    (Integer)  – 0-based display index (shown as index + 1)
%>
<div class="flex justify-between items-start mb-4">
  <h3 class="text-[16px] font-semibold text-gray-800"><%= index + 1 %>. <%= question.question_text %></h3>
  <label class="text-sm flex items-center gap-2 border border-gray-300 px-2.5 py-1 cursor-pointer hover:bg-gray-50 text-gray-500 ml-4 shrink-0 rounded-sm">
    <input
      type="radio"
      name="answers[<%= question.id %>]"
      value="skip"
      class="w-4 h-4"
      data-action="exercise-progress#update"
    />
    わからない
  </label>
</div>

<div class="space-y-2 text-[15px] text-gray-800 ml-1">
  <% Question::CHOICES.each do |choice| %>
    <label class="flex items-start gap-3 cursor-pointer p-2 rounded-sm border border-transparent hover:bg-gray-50 hover:border-gray-200 transition-colors">
      <input
        type="radio"
        name="answers[<%= question.id %>]"
        value="<%= choice %>"
        class="w-4 h-4 mt-0.5 flex-shrink-0"
        data-action="exercise-progress#update"
      />
      <span>(<%= choice %>) <%= question_choice_text(question, choice) %></span>
    </label>
  <% end %>
</div>
