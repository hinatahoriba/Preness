<% set_title = exercise_set_title(section_type: @section.section_type, part_type: @part.part_type, set_number: @question_set.display_order) %>
<% score_percent = @total_count.zero? ? 0 : ((@correct_count.to_f / @total_count) * 100).round(1) %>

<section class="min-h-screen bg-gray-50 px-6 py-8 flex justify-center">
  <div class="w-full max-w-4xl space-y-6">
    <div class="flex flex-wrap items-start justify-between gap-4">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-gray-400">Result</p>
        <h1 class="mt-1 text-2xl font-extrabold text-gray-900">採点結果</h1>
        <p class="mt-1 text-sm text-gray-500"><%= set_title %></p>
      </div>
    </div>

    <div class="bg-white border border-gray-200 rounded-sm p-6 flex justify-between items-center shadow-sm">
      <div class="flex flex-col gap-1">
        <span class="text-xs text-gray-500 font-medium tracking-wide">正答率</span>
        <span class="text-5xl font-semibold text-blue-500"><%= score_percent %>%</span>
      </div>

      <div class="flex flex-col items-end gap-2">
        <div class="border border-gray-200 rounded-sm px-6 py-2 bg-gray-50 text-gray-800 text-sm font-medium">
          正解数: <%= @correct_count %> / <%= @total_count %>
        </div>
        <span class="text-[10px] text-gray-400 tracking-wide">作成日: <%= @exercise.created_at.strftime("%Y/%m/%d") rescue Time.current.strftime("%Y/%m/%d") %></span>
      </div>
    </div>

    <div class="space-y-4">
      <div class="border-b border-gray-200 pb-2 flex justify-between items-center">
        <h2 class="text-lg font-bold text-gray-900">正誤/解説</h2>

        <%= form_with url: result_exercise_path(@exercise), method: :get, class: "m-0", data: { turbo: true } do |f| %>
          <%= f.hidden_field :attempt_id, value: @attempt.id %>
          <%= f.select :filter,
                options_for_select([["全問", "all"], ["間違った問題", "wrong"], ["あってた問題", "correct"]], @filter),
                {},
                onchange: "this.form.submit()",
                class: "block w-36 rounded-sm border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm py-1.5 px-3 bg-white text-gray-700 cursor-pointer" %>
        <% end %>
      </div>

      <% if @display_questions.empty? %>
        <div class="bg-white border border-gray-200 rounded-sm p-6 flex justify-center items-center shadow-sm">
          <p class="text-base font-semibold text-gray-400">
            該当する問題がありません。
          </p>
        </div>
      <% else %>
        <% @display_questions.each do |question| %>
          <% review = ExamSessions::QuestionReviewPresenter.new(question: question, answer: @answers_by_question_id[question.id], section_type: @section.section_type) %>
          <%= render "shared/exam/result/review_summary_card", question: question, review: review %>
        <% end %>
      <% end %>
    </div>

    <div class="flex flex-row items-stretch gap-4 mt-8 pb-12">
      <%= link_to exercises_path, class: "group flex-1 flex items-center justify-center gap-2 rounded-sm border border-gray-200 bg-white px-4 py-3 text-sm font-bold text-gray-600 transition-all hover:bg-gray-50 active:scale-[0.98]" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        <span>一覧へ戻る</span>
      <% end %>

      <%= link_to answer_exercise_path(@exercise), class: "group flex-1 flex items-center justify-center gap-2 rounded-sm bg-[#0f2361] px-4 py-3 text-sm font-bold text-white transition-all hover:bg-[#0a1845] active:scale-[0.98]" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
        </svg>
        <span>もう一度解く</span>
      <% end %>
    </div>
  </div>
</section>
