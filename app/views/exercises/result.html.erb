<% set_title = exercise_set_title(section_type: @section.section_type, part_type: @part.part_type, set_number: @question_set.display_order) %>
<% score_percent = @total_count.zero? ? 0 : ((@correct_count.to_f / @total_count) * 100).round(1) %>

<section class="min-h-screen bg-white px-6 py-10">
  <div class="mx-auto max-w-5xl">
    <div class="flex flex-wrap items-start justify-between gap-4">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-preness-500">Result</p>
        <h1 class="mt-2 text-3xl font-extrabold text-slate-900">採点結果</h1>
        <p class="mt-2 text-sm text-slate-600"><%= set_title %></p>
      </div>

      <div class="flex flex-wrap items-center gap-3">
        <%= link_to "もう一度解く", answer_exercise_path(@exercise), class: "inline-flex items-center rounded-lg border border-preness-300 px-5 py-2 text-sm font-semibold text-preness-700 hover:bg-preness-50" %>
        <%= link_to "一覧へ戻る", exercises_path, class: "inline-flex items-center rounded-lg bg-preness-500 px-5 py-2 text-sm font-semibold text-white hover:bg-preness-600" %>
      </div>
    </div>

    <div class="mt-8 rounded-2xl border border-slate-200 bg-white p-6">
      <div class="flex flex-wrap items-end justify-between gap-4">
        <div>
          <p class="text-sm font-semibold text-slate-500">正答率</p>
          <p class="mt-2 text-4xl font-extrabold text-slate-900">
            <%= @correct_count %>/<%= @total_count %>
            <span class="ml-2 text-base font-semibold text-slate-600">(<%= score_percent %>%)</span>
          </p>
          <p class="mt-2 text-sm text-slate-600">回答済み: <%= @answered_count %>/<%= @total_count %></p>
        </div>
        <div class="w-full max-w-sm">
          <div class="h-2 w-full overflow-hidden rounded-full bg-slate-100">
            <div class="h-full bg-emerald-500" style="width: <%= score_percent %>%;"></div>
          </div>
        </div>
      </div>
    </div>

    <div class="mt-10">
      <h2 class="text-lg font-bold text-slate-900">間違えた問題</h2>

      <% if @wrong_questions.empty? %>
        <p class="mt-3 rounded-2xl border border-emerald-200 bg-emerald-50 px-5 py-4 text-sm font-semibold text-emerald-900">
          全問正解です。
        </p>
      <% else %>
        <div class="mt-4 space-y-6">
          <% @wrong_questions.each do |question| %>
            <% answer = @answers_by_question_id[question.id] %>
            <% selected_choice = answer&.selected_choice %>
            <% correct_choice = question.correct_choice %>

            <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
              <div class="flex items-start gap-4">
                <span class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-red-50 text-sm font-bold text-red-700">
                  Q<%= question.display_order %>
                </span>

                <div class="min-w-0 flex-1">
                  <p class="text-sm font-semibold leading-relaxed text-slate-900"><%= question.question_text %></p>

                  <div class="mt-5 grid gap-3">
                    <div class="rounded-xl bg-red-50 px-4 py-3 text-sm text-red-800">
                      <p class="font-bold">あなたの回答</p>
                      <p class="mt-1 whitespace-pre-line">
                        <% if selected_choice.present? %>
                          <%= selected_choice %>. <%= question_choice_text(question, selected_choice) %>
                        <% else %>
                          未回答
                        <% end %>
                      </p>
                    </div>

                    <div class="rounded-xl bg-emerald-50 px-4 py-3 text-sm text-emerald-800">
                      <p class="font-bold">正解</p>
                      <p class="mt-1 whitespace-pre-line">
                        <%= correct_choice %>. <%= question_choice_text(question, correct_choice) %>
                      </p>
                    </div>

                    <div class="rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-700">
                      <p class="font-bold text-slate-900">解説</p>
                      <p class="mt-1 whitespace-pre-line"><%= question.explanation.presence || "解説はありません。" %></p>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</section>

