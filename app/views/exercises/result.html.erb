<% set_title = exercise_set_title(section_type: @section.section_type, part_type: @part.part_type, set_number: @question_set.display_order) %>
<% score_percent = @total_count.zero? ? 0 : ((@correct_count.to_f / @total_count) * 100).round(1) %>

<section class="min-h-screen bg-[#F3F4F6] px-6 py-10 flex justify-center">
  <div class="w-full max-w-4xl space-y-12">
    <!-- Header -->
    <div class="flex flex-wrap items-start justify-between gap-4">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-gray-500">Result</p>
        <h1 class="mt-2 text-3xl font-extrabold text-gray-900">採点結果</h1>
        <p class="mt-2 text-sm text-gray-600"><%= set_title %></p>
      </div>

      <div class="flex flex-wrap items-center gap-3">
        <%= link_to "もう一度解く", answer_exercise_path(@exercise), class: "inline-flex items-center rounded-lg border border-gray-300 px-5 py-2 text-sm font-semibold text-gray-700 hover:bg-gray-50 bg-white" %>
        <%= link_to "一覧へ戻る", exercises_path, class: "inline-flex items-center rounded-lg bg-[#3B82F6] px-5 py-2 text-sm font-semibold text-white hover:bg-blue-600" %>
      </div>
    </div>

    <!-- Score Card -->
    <div class="bg-white border border-gray-200 rounded-xl p-8 flex justify-between items-center shadow-sm">
      <div class="flex flex-col gap-2">
        <span class="text-sm text-gray-500 font-medium tracking-wide">正答率</span>
        <span class="text-6xl font-semibold text-[#3B82F6]"><%= score_percent %>%</span>
      </div>
      
      <div class="flex flex-col items-end gap-3">
        <div class="border border-gray-200 rounded-lg px-8 py-3 bg-[#FAFAFA] text-gray-800 text-sm font-medium">
          正解数: <%= @correct_count %> / <%= @total_count %>
        </div>
        <span class="text-xs text-gray-400 tracking-wide">作成日: <%= @exercise.created_at.strftime("%Y/%m/%d") rescue Time.current.strftime("%Y/%m/%d") %></span>
      </div>
    </div>

    <!-- Questions Details -->
    <div class="space-y-6">
      <div class="border-b border-gray-200 pb-3 flex justify-between items-center">
        <h2 class="text-xl font-bold text-gray-900">正誤/解説</h2>

        <%= form_with url: result_exercise_path(@exercise), method: :get, class: "m-0", data: { turbo: true } do |f| %>
          <%= f.select :filter, 
                options_for_select([['全問', 'all'], ['間違った問題', 'wrong'], ['あってた問題', 'correct']], @filter), 
                {}, 
                onchange: "this.form.submit()", 
                class: "block w-40 rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm py-2 px-3 bg-white text-gray-700 cursor-pointer" %>
        <% end %>
      </div>

      <% if @display_questions.empty? %>
        <div class="bg-white border border-gray-200 rounded-xl p-8 flex justify-center items-center shadow-sm">
          <p class="text-lg font-semibold text-gray-500">
            該当する問題がありません。
          </p>
        </div>
      <% else %>
        <% @display_questions.each do |question| %>
          <% answer = @answers_by_question_id[question.id] %>
          <% selected_choice = answer&.selected_choice %>
          <% correct_choice = question.correct_choice %>
          <% is_correct = answer&.is_correct == true %>

          <div class="bg-white border border-gray-200 rounded-xl overflow-hidden shadow-sm">
            <div class="border-b border-gray-100 px-6 py-4 flex justify-between items-center bg-gray-50">
              <span class="text-sm font-bold text-gray-700">Q<%= question.display_order %></span>
              <% if is_correct %>
                <span class="text-sm font-bold text-emerald-600 bg-emerald-100 px-3 py-1 rounded-full">正解</span>
              <% else %>
                <span class="text-sm font-bold text-[#EF4444] bg-red-50 px-3 py-1 rounded-full">不正解</span>
              <% end %>
            </div>

            <div class="p-6 space-y-8">
              <h3 class="text-[17px] font-bold text-gray-900 tracking-wide">
                <%= question.question_text %>
              </h3>

              <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                <div class="border border-gray-200 rounded-xl p-5 <%= is_correct ? 'bg-emerald-50/50' : 'bg-red-50/30' %>">
                  <p class="text-xs text-gray-500 mb-4">あなたの解答</p>
                  <div class="flex items-center gap-4">
                    <div class="w-8 h-8 rounded-full <%= is_correct ? 'bg-emerald-500' : 'bg-[#EF4444]' %> text-white flex justify-center items-center text-sm font-medium">
                      <%= selected_choice.present? ? selected_choice.upcase : "-" %>
                    </div>
                    <span class="text-gray-800">
                      <% if selected_choice.present? %>
                        <%= question_choice_text(question, selected_choice) %>
                      <% else %>
                        未回答
                      <% end %>
                    </span>
                  </div>
                </div>

                <div class="border border-gray-200 rounded-xl p-5 bg-blue-50/30">
                  <p class="text-xs text-gray-500 mb-4">正解</p>
                  <div class="flex items-center gap-4">
                    <div class="w-8 h-8 rounded-full bg-[#3B82F6] text-white flex justify-center items-center text-sm font-medium">
                      <%= correct_choice.upcase %>
                    </div>
                    <span class="text-gray-900 font-medium">
                      <%= question_choice_text(question, correct_choice) %>
                    </span>
                  </div>
                </div>
              </div>

              <div class="border border-gray-200 rounded-xl p-5 bg-[#FAFAFA]">
                <p class="text-xs text-gray-500 mb-3">解説</p>
                <div class="text-sm text-gray-800 leading-relaxed tracking-wide whitespace-pre-line">
                  <%= question.explanation.presence || "解説はありません。" %>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
</section>
