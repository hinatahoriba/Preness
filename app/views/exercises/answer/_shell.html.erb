<%# Locals:
#   presenter (ExamSessions::AnswerPresenter)
%>
<div
  class="<%= presenter.wrapper_class %>"
  data-controller="exercises--progress"
  data-exercises--progress-total-count-value="<%= presenter.total_count %>"
  data-exercises--progress-require-all-answered-value="<%= presenter.require_all_answered? %>"
>
  <header class="flex-shrink-0 flex items-stretch justify-between h-14 md:h-16 border-b-[3px] border-[#1a1b4b] bg-white sticky top-0 z-50 font-sans">
    <div class="flex items-center px-3 md:px-6 md:w-1/3 min-w-0">
      <h1 class="hidden md:block text-[11px] font-bold tracking-[0.12em] text-gray-800 uppercase whitespace-nowrap truncate font-serif mr-4">
        <%= presenter.title %>
      </h1>
    </div>

    <div class="hidden md:flex flex-col items-center justify-center border-l border-r border-gray-200 px-4 md:w-1/3">
      <div class="text-xs text-gray-600 mb-1">
        回答済み :
        <span class="text-gray-800 font-medium" data-exercises--progress-target="answeredCount"><%= presenter.answered_count %></span>/<%= presenter.total_count %>問
      </div>
      <div class="flex flex-wrap justify-center gap-1 w-full max-w-[250px]">
        <% presenter.questions.each do |question| %>
          <div
            class="w-3 h-1 bg-gray-300"
            data-exercises--progress-target="indicator"
            data-question-id="<%= question.id %>"
          ></div>
        <% end %>
      </div>
    </div>

    <div class="flex items-center justify-end px-3 md:px-6 gap-2 md:gap-4 md:w-1/3 text-xs md:text-sm">
      <div class="flex gap-1 md:gap-2">
        <% presenter.secondary_links.each do |link| %>
          <%= link_to link[:label], link[:path],
                class: "px-3 py-1.5 md:px-5 md:py-2 border border-gray-300 hover:bg-gray-50 transition-colors text-gray-700 whitespace-nowrap" %>
        <% end %>
      </div>

      <%= button_tag presenter.submit_label,
            type: :submit,
            form: presenter.form_id,
            disabled: presenter.require_all_answered?,
            "data-exercises--progress-target": "submitButton",
            class: "px-4 py-1.5 md:px-8 md:py-2 bg-[#1a1b4b] text-white hover:bg-blue-900 transition-colors disabled:opacity-40 disabled:cursor-not-allowed cursor-pointer whitespace-nowrap" %>
    </div>
  </header>

  <%= form_with(
    url: presenter.form_url,
    method: :post,
    id: presenter.form_id,
    class: presenter.form_class
  ) do %>
    <%= render presenter.layout_partial, **presenter.layout_locals %>
  <% end %>
</div>
