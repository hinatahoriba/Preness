<%# Locals: question_set (QuestionSet) - with passage + questions %>

<div class="flex-1 flex overflow-hidden">
  <%# Left: Passage text (scrollable) %>
  <div class="w-1/2 overflow-y-auto px-10 pt-7 pb-24">
    <h2 class="text-[10px] font-bold text-gray-400 tracking-widest mb-5 uppercase font-sans">
      REFERENCE TEXT
    </h2>
    <div class="text-[15.5px] leading-[2] text-gray-800 space-y-5 text-justify font-serif">
      <%= simple_format(question_set.passage.to_s) %>
    </div>
  </div>

  <%# Right: Questions (scrollable) %>
  <div class="w-1/2 border-l border-gray-100 overflow-y-auto px-10 pt-7 pb-24">
    <% question_set.questions.order(:display_order).each_with_index do |question, index| %>
      <div class="mb-10 pb-10 border-b border-gray-100 last:border-0 last:mb-0">
        <%= render "exercises/question_item", question: question, index: index %>
      </div>
    <% end %>
  </div>
</div>
