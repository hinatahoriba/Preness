<%# Locals: question_set (QuestionSet) - with passage + questions %>

<div class="flex-1 flex overflow-hidden">
  <%# Left: Passage text (scrollable) %>
  <div class="w-1/2 overflow-y-auto px-10 pt-7 pb-24 bg-white border-r border-gray-200">
    <h2 class="text-[10px] font-bold text-gray-400 tracking-widest mb-5 uppercase">
      REFERENCE TEXT
    </h2>
    <div class="text-[15px] leading-[1.9] text-gray-800 space-y-4">
      <%= simple_format(question_set.passage.to_s) %>
    </div>
  </div>

  <%# Right: Questions (scrollable) %>
  <div class="w-1/2 overflow-y-auto px-10 pt-7 pb-24 bg-[#f4f5f7]">
    <% question_set.questions.order(:display_order).each_with_index do |question, index| %>
      <div class="bg-white rounded-sm border border-gray-200 shadow-sm p-5 mb-5 last:mb-0">
        <%= render "exercises/question_item", question: question, index: index %>
      </div>
    <% end %>
  </div>
</div>
