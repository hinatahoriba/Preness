<% content_for :title, "Preness - Exercises" %>

<div class="bg-white min-h-screen">
  <header class="flex justify-between items-center py-4 px-8 border-b border-gray-100">
    <%= link_to root_path, class: "text-[#4b9b94] text-xl font-bold tracking-tight" do %>
      Preness
    <% end %>
    <div class="flex items-center gap-6">
      <% unless current_user.premium? %>
        <div class="flex items-center bg-[#f0fdf4] border border-[#bbf7d0] px-3 py-1 rounded-full shadow-sm">
          <span class="text-[11px] font-bold text-[#16a34a] mr-2">今日の残り</span>
          <span class="text-sm font-extrabold text-[#15803d]"><%= [0, 3 - current_user.today_exercise_count].max %></span>
          <span class="text-[11px] font-bold text-[#16a34a] ml-0.5">/ 3</span>
        </div>
      <% end %>
      <%= link_to "マイページ", mypage_path, class: "text-[13px] font-medium text-gray-600 hover:text-[#4b9b94] transition-colors" %>
    </div>
  </header>

  <main class="max-w-5xl mx-auto py-12 px-8">
    <% Section::SECTION_TYPES.each do |section_type| %>
      <% entries = @exercise_entries_by_section_type.fetch(section_type, []) %>
      <% next if entries.empty? %>

      <div class="flex items-center mb-8 mt-16 first:mt-0">
        <div class="w-[3px] h-6 bg-[#4b9b94] mr-3 rounded-sm"></div>
        <h1 class="text-[24px] font-bold text-[#1a2f33]"><%= exercise_section_label(section_type) %></h1>
      </div>

      <% entries.group_by { _1.fetch(:part_type) }
          .sort_by { |_, part_entries| part_entries.first.fetch(:part_display_order) }
          .each do |part_type, part_entries| %>
        <% part_label = exercise_part_label(part_type) %>

        <section class="mb-10 last:mb-0">
          <div class="flex justify-between items-center mb-4">
            <h2 class="text-lg font-bold text-[#1a2f33]"><%= part_label || "Exercises" %></h2>
            <% 
              unattempted_entry = part_entries.reject { _1.fetch(:attempted) }.min_by { _1.fetch(:set_number) }
              target_exercise = (unattempted_entry || part_entries.min_by { _1.fetch(:set_number) }).fetch(:exercise)
            %>
            <%= link_to answer_exercise_path(target_exercise), class: "flex items-center text-[#4b9b94] font-bold text-sm tracking-widest hover:opacity-80 transition-opacity" do %>
              START
              <svg class="w-3 h-3 ml-2 fill-current" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
            <% end %>
          </div>
          
          <div class="flex flex-wrap gap-3">
            <% part_entries.sort_by { _1.fetch(:set_number) }.each do |entry| %>
              <% exercise = entry.fetch(:exercise) %>
              <% set_number = entry.fetch(:set_number) %>
              <% attempted = entry.fetch(:attempted) %>
              <% correct_count = entry.fetch(:correct_count) %>
              <% total_count = entry.fetch(:total_count) %>

              <%
                box_class = if attempted
                              if correct_count == total_count
                                "bg-[#f0fdf4] border border-[#bbf7d0] text-[#16a34a]"
                              else
                                "bg-[#fffcf0] border border-[#fde68a] text-[#d97706]"
                              end
                            else
                              "bg-[#f8f9fa] text-gray-400"
                            end
              %>

              <%= link_to answer_exercise_path(exercise), 
                  class: "w-14 h-12 flex flex-col items-center justify-center rounded-md transition-all duration-200 #{box_class} font-medium",
                  title: exercise_set_title(section_type: section_type, part_type: part_type, set_number: set_number) do %>
                <% if attempted %>
                  <span class="text-[9px] font-medium leading-none mb-1">Set <%= set_number %></span>
                  <span class="text-xs font-bold leading-none"><%= correct_count %>/<%= total_count %></span>
                <% else %>
                  <span class="text-sm"><%= set_number %></span>
                <% end %>
              <% end %>
            <% end %>
          </div>
        </section>
      <% end %>
    <% end %>
  </main>
</div>
