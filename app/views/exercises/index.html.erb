<% content_for :title, "Preness - Exercises" %>

<div class="bg-white min-h-screen">
  <header class="flex justify-between items-center py-4 px-8 border-b border-gray-100">
    <%= link_to root_path, class: "text-[#4b9b94] text-xl font-bold tracking-tight" do %>
      Preness
    <% end %>
    <div class="flex items-center gap-4">
      <%= link_to "マイページ", mypage_path, class: "text-[13px] font-medium text-gray-600 hover:text-[#4b9b94] transition-colors" %>
    </div>
  </header>

  <main class="max-w-5xl mx-auto py-12 px-8">
    <% @index_presenter.section_groups.each do |section_group| %>
      <div class="flex items-center mb-8 mt-16 first:mt-0">
        <div class="w-[3px] h-6 bg-[#4b9b94] mr-3 rounded-sm"></div>
        <h1 class="text-[24px] font-bold text-[#1a2f33]"><%= section_group[:section_label] %></h1>
      </div>

      <% section_group[:parts].each do |part_group| %>
        <section class="mb-10 last:mb-0">
          <div class="flex justify-between items-center mb-4">
            <h2 class="text-lg font-bold text-[#1a2f33]"><%= part_group[:part_label] %></h2>
            <%= link_to answer_exercise_path(part_group[:start_exercise]), class: "flex items-center text-[#4b9b94] font-bold text-sm tracking-widest hover:opacity-80 transition-opacity" do %>
              START
              <svg class="w-3 h-3 ml-2 fill-current" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
            <% end %>
          </div>

          <div class="flex flex-wrap gap-3">
            <% part_group[:entries].each do |entry| %>
              <%= link_to answer_exercise_path(entry[:exercise]),
                  class: "w-14 h-12 flex flex-col items-center justify-center rounded-md transition-all duration-200 #{entry[:box_class]} font-medium",
                  title: entry[:title] do %>
                <% if entry[:attempted] %>
                  <span class="text-[9px] font-medium leading-none mb-1">Set <%= entry[:set_number] %></span>
                  <span class="text-xs font-bold leading-none"><%= entry[:correct_count] %>/<%= entry[:total_count] %></span>
                <% else %>
                  <span class="text-sm"><%= entry[:set_number] %></span>
                <% end %>
              <% end %>
            <% end %>
          </div>
        </section>
      <% end %>
    <% end %>
  </main>
</div>
