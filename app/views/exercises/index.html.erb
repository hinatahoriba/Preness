<% content_for :title, "Preness - Exercises" %>

<main class="min-h-screen">
  <div class="mx-auto max-w-6xl px-6 py-10 md:px-10 md:py-14">
    <header class="mt-6 md:mt-8">
      <h1 class="text-2xl md:text-3xl font-bold tracking-tight text-slate-800">
        セクション別演習
      </h1>
      <p class="mt-2 text-sm md:text-base text-slate-500">
        演習するセクションを選択してください。
      </p>
    </header>

    <section class="mt-10 md:mt-12">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
        <% @part_selection_presenter.part_cards.each do |card| %>
          <article class="rounded-[28px] border border-slate-200/70 bg-white p-7 shadow-[0_10px_30px_rgba(15,23,42,0.06)]">
            <div class="flex items-center gap-3">
              <div class="h-12 w-12 rounded-2xl <%= card[:icon_bg] %> flex items-center justify-center">
                <svg class="h-6 w-6 <%= card[:icon_color] %>" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
                  <%= card[:icon_svg].html_safe %>
                </svg>
              </div>
              <h2 class="text-lg font-bold text-slate-800"><%= card[:label] %></h2>
            </div>
            <div class="mt-6">
              <%= link_to exercises_part_path(section_type: card[:section_type], part_type: card[:part_type]),
                    class: "w-full inline-flex items-center justify-center gap-2 rounded-xl bg-[#43b3b3] px-4 py-3 text-sm font-bold text-white shadow-sm hover:brightness-105 transition" do %>
                <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M8 5v14l11-7z" />
                </svg>
                演習を始める
              <% end %>
            </div>
          </article>
        <% end %>
      </div>
    </section>
  </div>
</main>
