<%# Locals: questions (Array<Question>) - all questions in Part A, ordered %>

<div
  class="pb-16 max-w-[1400px] mx-auto px-10"
  data-controller="exercise-audio-custom-player"
>
  <main class="pt-10">
    <div class="border-y border-gray-300 py-3 mb-8">
      <h1 class="text-2xl font-bold text-center tracking-[0.15em] text-gray-800">
        LISTENING COMPREHENSION
      </h1>
    </div>

    <div class="mb-10">
      <h2 class="text-xl font-bold mb-3 border-b border-gray-300 pb-2">PART A</h2>
      <p class="text-[15px] leading-relaxed text-gray-700">
        <span class="font-bold underline underline-offset-2">Directions:</span>
        In Part A you will hear short conversations between two people. After each conversation, you will hear a question about the conversation. The conversations and questions will not be repeated. After you hear a question, read the four possible answers and choose the best answer.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-x-12 gap-y-6">
      <% questions.each_with_index do |question, index| %>
        <% audio_url = question.audio_url.presence || question.question_set&.audio_url %>
        <div class="bg-white rounded-sm border border-gray-200 shadow-sm p-5">
          <% if audio_url.present? %>
            <%= render "exercises/audio_player", url: audio_url, label: "LISTENING AUDIO", compact: true %>
          <% end %>
          <%= render "exercises/question_item", question: question, index: index %>
        </div>
      <% end %>
    </div>
  </main>
</div>
