<% set_title = exercise_set_title(section_type: @section.section_type, part_type: @part.part_type, set_number: @question_set.display_order) %>

<section class="min-h-screen bg-gray-50 px-6 py-8 flex justify-center">
  <div class="w-full max-w-4xl space-y-6">
    <!-- Header -->
    <div class="flex flex-wrap items-start justify-between gap-4">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-gray-400">History</p>
        <h1 class="mt-1 text-2xl font-extrabold text-gray-900">結果履歴</h1>
        <p class="mt-1 text-sm text-gray-500"><%= set_title %></p>
      </div>
    </div>

    <!-- Attempts List -->
    <div class="space-y-3">
      <% @attempts.each_with_index do |attempt, index| %>
        <% total = @questions.size %>
        <% correct = attempt.answers.count(&:is_correct) %>
        <% score_percent = total.zero? ? 0 : ((correct.to_f / total) * 100).round(1) %>

        <%= link_to result_exercise_path(@exercise, attempt_id: attempt.id),
              class: "block bg-white border border-gray-200 rounded-sm p-5 shadow-sm hover:bg-gray-50 transition-colors" do %>
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-4">
              <span class="text-xs font-semibold text-gray-400 w-6 text-right"><%= @attempts.size - index %></span>
              <div>
                <p class="text-sm font-bold text-gray-800">
                  <%= attempt.created_at.strftime("%Y/%m/%d %H:%M") %>
                </p>
                <p class="text-xs text-gray-500 mt-0.5">
                  正解数: <%= correct %> / <%= total %>
                </p>
              </div>
            </div>

            <div class="flex items-center gap-4">
              <span class="text-2xl font-semibold <%= score_percent >= 80 ? 'text-emerald-500' : score_percent >= 60 ? 'text-yellow-500' : 'text-red-500' %>">
                <%= score_percent %>%
              </span>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>

    <!-- Bottom Buttons -->
    <div class="flex flex-row items-stretch gap-4 mt-8 pb-12">
      <%= link_to exercises_path, class: "group flex-1 flex items-center justify-center gap-2 rounded-sm border border-gray-200 bg-white px-4 py-3 text-sm font-bold text-gray-600 transition-all hover:bg-gray-50 active:scale-[0.98]" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        <span>一覧へ戻る</span>
      <% end %>

      <%= link_to answer_exercise_path(@exercise), class: "group flex-1 flex items-center justify-center gap-2 rounded-sm bg-[#0f2361] px-4 py-3 text-sm font-bold text-white transition-all hover:bg-[#0a1845] active:scale-[0.98]" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
        </svg>
        <span>もう一度解く</span>
      <% end %>
    </div>
  </div>
</section>
