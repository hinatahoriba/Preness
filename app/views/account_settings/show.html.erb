<% content_for :body_class, "bg-[#f9fafb] text-[#374151] h-screen" %>

<div class="flex h-full">
  <%= render 'shared/sidebar', active_page: :account_settings %>

  <%# メインコンテンツ %>
  <main class="flex-1 p-8 overflow-y-auto">
    <div class="max-w-4xl mx-auto">
      <div class="mb-6">
        <h2 class="text-2xl font-bold mb-2">アカウント設定</h2>
        <p class="text-sm text-gray-500">登録情報やプランの管理ができます。</p>
      </div>

      <div class="bg-white border border-gray-200 rounded-lg shadow-sm">

        <%# 基本プロフィール %>
        <div class="flex items-center justify-between px-6 py-4 border-b border-gray-200 bg-[#fbfbfb] rounded-t-lg">
          <div class="flex items-center space-x-2 text-gray-800 font-bold">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-teal-600">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
            </svg>
            <span>基本プロフィール</span>
          </div>
          <%= link_to edit_user_profile_path, class: "text-sm text-teal-600 hover:text-teal-700 font-medium" do %>
            編集する
          <% end %>
        </div>

        <div class="p-8">
          <%# プロフィール情報 %>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-y-8 gap-x-12 pb-8 border-b border-gray-100">
            <div>
              <p class="text-xs text-gray-500 mb-2">氏名</p>
              <p class="font-bold text-lg"><%= @user_profile&.full_name %></p>
              <p class="text-xs text-gray-400 mt-1"><%= @user_profile&.full_name_kana %></p>
            </div>

            <div>
              <p class="text-xs text-gray-500 mb-2">年齢</p>
              <p class="font-bold"><%= @user_profile&.age %>歳</p>
            </div>

            <div>
              <p class="text-xs text-gray-500 mb-2">所属</p>
              <p class="font-bold"><%= @user_profile&.affiliation %></p>
            </div>

            <div>
              <p class="text-xs text-gray-500 mb-2">ニックネーム</p>
              <p class="font-bold"><%= @user_profile&.nickname %></p>
            </div>
          </div>

          <%# メールアドレス・パスワード %>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-y-8 gap-x-12 pt-8">
            <div>
              <p class="text-xs text-gray-500 mb-2">メールアドレス</p>
              <div class="flex items-center justify-between">
                <div class="flex items-center space-x-2">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 text-gray-400">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
                  </svg>
                  <p class="font-bold"><%= current_user.email %></p>
                </div>
              </div>
            </div>

            <div>
              <p class="text-xs text-gray-500 mb-2">パスワード</p>
              <div class="flex items-center justify-between">
                <p class="font-bold tracking-widest text-xl leading-none pt-1">••••••••</p>
                <%= link_to "変更", edit_user_registration_path, class: "text-sm text-teal-600 hover:text-teal-700 font-medium" %>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </main>
</div>
