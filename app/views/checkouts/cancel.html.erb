<% content_for :body_class, "bg-[#f9fafb] text-[#374151] min-h-screen" %>

<main class="max-w-2xl mx-auto p-8 mt-16">
  <div class="bg-white rounded-3xl shadow-sm border border-gray-100 p-10 text-center">
    <!-- キャンセルアイコン -->
    <div class="w-20 h-20 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-6">
      <svg class="w-10 h-10 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </div>

    <h1 class="text-2xl font-extrabold text-gray-900 mb-3">購入がキャンセルされました</h1>
    <p class="text-gray-500 mb-8">
      <span class="font-bold text-gray-700"><%= @mock.title %></span> の購入がキャンセルされました。<br>
      いつでも再度購入できます。
    </p>

    <%= link_to mocks_path,
          class: "inline-flex items-center space-x-2 bg-[#34a0a4] hover:bg-[#2d8b8e] text-white px-8 py-3 rounded-2xl text-sm font-bold transition-all shadow-lg hover:shadow-[#34a0a4]/30" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
      </svg>
      <span>模擬試験一覧へ戻る</span>
    <% end %>
  </div>
</main>
