<%# Locals:
#   question (Question) – question record
#   index    (Integer)  – 0-based display index (shown as index + 1)
%>
<div class="flex justify-between items-start mb-4">
  <h3 class="text-[17px] font-bold font-serif"><%= index + 1 %>. <%= question.question_text %></h3>
  <label class="font-sans text-sm flex items-center gap-2 border border-gray-300 px-2.5 py-1 cursor-pointer hover:bg-gray-50 text-gray-600 ml-4 shrink-0">
    <input
      type="radio"
      name="answers[<%= question.id %>]"
      value="UNKNOWN"
      class="w-4 h-4"
      style="accent-color: #1a1b4b"
      data-action="mock-progress#update"
    />
    わからない
  </label>
</div>

<div class="space-y-3 text-[16px] text-gray-800 ml-2 font-serif">
  <% Question::CHOICES.each do |choice| %>
    <label class="flex items-start gap-3 cursor-pointer hover:bg-gray-50 p-1 rounded">
      <input
        type="radio"
        name="answers[<%= question.id %>]"
        value="<%= choice %>"
        class="w-[17px] h-[17px] mt-0.5 flex-shrink-0"
        style="accent-color: #1a1b4b"
        data-action="mock-progress#update"
      />
      <span>(<%= choice %>) <%= question_choice_text(question, choice) %></span>
    </label>
  <% end %>
</div>
