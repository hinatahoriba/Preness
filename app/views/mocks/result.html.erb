<section class="min-h-screen bg-gray-50 px-6 py-8 flex justify-center" data-controller="modal">
  <div class="w-full max-w-4xl space-y-6">
    <div class="flex flex-wrap items-start justify-between gap-4">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-gray-400">Result</p>
        <h1 class="mt-1 text-2xl font-extrabold text-gray-900">模擬試験 採点結果</h1>
        <p class="mt-1 text-sm text-gray-500"><%= @mock.title %></p>
      </div>
    </div>

    <div class="bg-white border border-gray-200 rounded-sm p-6 flex flex-col md:flex-row justify-between md:items-center shadow-sm gap-6 md:gap-12">
      <div class="flex flex-col gap-1 w-full md:w-auto text-center md:text-left">
        <span class="text-xs text-gray-500 font-medium tracking-wide">トータル正答率</span>
        <span class="text-5xl font-semibold text-blue-500"><%= @result_presenter.total_percent %>%</span>
      </div>

      <div class="flex flex-col gap-3 flex-1 border-t md:border-t-0 md:border-l border-gray-100 pt-4 md:pt-0 md:pl-8">
        <% @section_results.each do |result| %>
          <% section_percent = result[:total_count].zero? ? 0 : ((result[:correct_count].to_f / result[:total_count]) * 100).round(1) %>
          <div class="flex justify-between items-center text-sm">
            <span class="text-gray-700 font-medium"><%= mock_section_label(result[:section].section_type) %></span>
            <div class="text-right whitespace-nowrap">
              <span class="text-gray-900 font-bold mr-3 inline-block w-16"><%= result[:correct_count] %> / <%= result[:total_count] %></span>
              <span class="text-blue-500 font-semibold w-12 inline-block text-right"><%= section_percent %>%</span>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <div class="space-y-6 pt-6">
      <div class="border-b border-gray-200 pb-2 flex flex-col sm:flex-row justify-between sm:items-center gap-4">
        <div class="flex items-center">
          <div class="w-1.5 h-6 bg-[#1a365d] mr-3"></div>
          <h2 class="text-lg font-bold text-[#1a365d] tracking-wide">問題ログ</h2>
        </div>

        <%= form_with url: result_mock_path(@mock), method: :get, class: "m-0 flex flex-wrap gap-2 justify-end", data: { turbo: true } do |f| %>
          <%= f.hidden_field :attempt_id, value: @attempt.id %>
          <%= f.select :part_filter,
                options_for_select([["全てのPart", "all"]] + @available_sections, @part_filter),
                {},
                onchange: "this.form.submit()",
                class: "block w-40 rounded-sm border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm py-1.5 px-3 bg-white text-gray-700 cursor-pointer" %>
          <%= f.select :filter,
                options_for_select([["全問", "all"], ["間違った問題", "wrong"], ["あってた問題", "correct"]], @filter),
                {},
                onchange: "this.form.submit()",
                class: "block w-36 rounded-sm border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm py-1.5 px-3 bg-white text-gray-700 cursor-pointer" %>
        <% end %>
      </div>

      <% if !@result_presenter.has_display_questions? %>
        <div class="bg-white border border-gray-200 rounded-sm p-6 flex justify-center items-center shadow-sm mt-4">
          <p class="text-base font-semibold text-gray-400">
            該当する問題がありません。
          </p>
        </div>
      <% else %>
        <div class="bg-white border border-gray-200 shadow-sm mt-4 rounded-sm">
          <div class="overflow-auto max-h-[500px]">
            <table class="w-full text-sm text-left border-collapse whitespace-nowrap">
              <thead class="bg-[#1a365d] text-white border border-[#1a365d] sticky top-0 z-10">
                <tr>
                  <th class="px-4 py-2.5 font-medium w-12 text-center border border-white/20">No.</th>
                  <th class="px-4 py-2.5 font-medium border border-white/20">タイプ</th>
                  <th class="px-4 py-2.5 font-medium w-24 text-center border border-white/20">正解</th>
                  <th class="px-4 py-2.5 font-medium w-32 text-center border border-white/20">あなたの解答</th>
                  <th class="px-4 py-2.5 font-medium w-32 text-center border border-white/20">判定(◯/×)</th>
                </tr>
              </thead>
              <tbody>
                <% @result_presenter.table_rows.each do |row| %>
                  <tr class="even:bg-gray-50 odd:bg-white hover:bg-blue-50/50 transition-colors cursor-pointer" data-action="click->modal#open" data-modal-id="modal-question-<%= row[:question].id %>">
                    <td class="px-4 py-3 text-slate-500 text-center border border-slate-200"><%= row[:number] %></td>
                    <td class="px-4 py-3 text-slate-600 border border-slate-200"><%= row[:section_name] %></td>
                    <td class="px-4 py-3 text-slate-500 text-center font-bold text-[#1a365d] border border-slate-200">
                      <%= row[:review].correct_choice.upcase %>
                    </td>
                    <td class="px-4 py-3 text-slate-500 text-center border border-slate-200">
                      <%= row[:review].selected_choice_display %>
                    </td>
                    <td class="px-4 py-3 text-center <%= row[:review].correct? ? 'text-emerald-600' : 'text-red-500' %> font-bold border border-slate-200">
                      <%= row[:review].correct? ? "◯" : "×" %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      <% end %>
    </div>

    <div class="flex flex-row items-stretch gap-4 mt-8 pb-12">
      <%= link_to mypage_path, class: "group w-full flex items-center justify-center gap-2 rounded-sm bg-[#0f2361] px-4 py-3 text-sm font-bold text-white transition-all hover:bg-[#0a1845] active:scale-[0.98]" do %>
        <span>マイページへ戻る</span>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M14 5l7 7m0 0l-7 7m7-7H3" />
        </svg>
      <% end %>
    </div>
  </div>
</section>

<% @result_presenter.filtered_sections.each do |result| %>
  <% result[:display_questions].each do |question| %>
    <% review = ExamSessions::QuestionReviewPresenter.new(question: question, answer: result[:answers_by_question_id][question.id], section_type: result[:section].section_type) %>

    <div id="modal-question-<%= question.id %>" data-controller="modal" class="hidden fixed inset-0 bg-slate-900/50 flex justify-center items-center z-50 p-4 modal-container" data-action="click->modal#closeBackground">
      <div class="bg-white rounded shadow-xl w-full max-w-[700px] max-h-[90vh] flex flex-col">
        <div class="flex justify-between items-center px-8 py-5 border-b border-gray-100 shrink-0">
          <h2 class="text-[1.1rem] font-bold text-[#2C3358]">問題詳細 (Q<%= question.display_order %>)</h2>
          <button class="text-gray-400 hover:text-gray-600 transition-colors" data-action="click->modal#close">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
        <%= render "shared/exam/result/review_detail_content", question: question, review: review %>
      </div>
    </div>
  <% end %>
<% end %>
