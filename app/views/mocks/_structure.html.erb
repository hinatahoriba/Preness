<%# Locals: questions (Array<Question>) - all questions in the Structure section %>

<div class="pb-16 max-w-5xl mx-auto px-8">
  <main class="pt-10">
    <% if local_assigns[:part_label].present? %>
      <h2 class="text-2xl font-bold mb-4 border-b border-black pb-2 font-serif"><%= part_label %></h2>
    <% end %>
    <p class="text-[14px] leading-relaxed text-gray-800 mb-10 font-serif">
      <span class="font-bold underline">Directions:</span>
      <% if (local_assigns[:part_label] || "").include?("B") %>
        Part B questions each have four underlined words or phrases. Choose the one underlined word or phrase that must be changed for the sentence to be correct.
      <% else %>
        Part A questions are incomplete sentences. Beneath each sentence you will see four words or phrases, marked (A), (B), (C), and (D). Choose the one word or phrase that best completes the sentence.
      <% end %>
    </p>

    <div class="flex flex-col gap-10">
      <% questions.each_with_index do |question, index| %>
        <div class="question-block">
          <%= render "mocks/question_item", question: question, index: index %>
        </div>
      <% end %>
    </div>
  </main>
</div>
