<% if parts_accuracy[:listening] %>
  <% listening = parts_accuracy[:listening] %>
  <div class="text-[16px] font-bold text-[#1e3a5f] bg-[#eef3fa] px-4 py-2.5 rounded-md my-6 mb-4">LISTENING</div>
  <div class="grid grid-cols-3 gap-4 mb-6">
    <div class="bg-white border border-[#dde3ed] rounded-[10px] p-5">
      <div class="text-[13px] font-semibold text-[#1e3a5f] mb-1">Part別正答率</div>
      <div class="text-[11px] text-[#6b7c93] mb-4">&nbsp;</div>
      <div class="py-2">
        <% [[:part_a, "Part A"], [:part_b, "Part B"], [:part_c, "Part C"]].each do |key, label| %>
          <% data = listening[key] %>
          <% if data %>
            <div class="<%= 'mb-3' unless key == :part_c %>">
              <div class="flex justify-between text-[12px] mb-1">
                <span><%= label %></span>
                <span class="<%= data[:pct] < 70 ? 'text-[#e8703a]' : 'text-[#1e3a5f]' %> font-semibold"><%= data[:pct] %>%</span>
              </div>
              <div class="bg-[#eef3fa] rounded h-2">
                <div class="<%= data[:pct] < 70 ? 'bg-[#e8703a]' : 'bg-[#1e3a5f]' %> h-full rounded" style="width: <%= data[:pct] %>%"></div>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
    <div class="bg-white border border-[#dde3ed] rounded-[10px] p-5 col-span-2">
      <div class="text-[13px] font-semibold text-[#1e3a5f] mb-1">Part別レーダーチャート</div>
      <div class="text-[11px] text-[#6b7c93] mb-4">Part A / Part B / Part C の正答率</div>
      <div class="flex justify-center items-center py-2">
        <canvas id="radarListening" width="360" height="320"
          data-values="<%= [:part_a, :part_b, :part_c].map { |k| listening[k]&.dig(:pct) || 0 }.join(',') %>">
        </canvas>
      </div>
    </div>
  </div>
<% end %>
