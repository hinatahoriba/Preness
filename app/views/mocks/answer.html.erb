<% set_title = mock_section_part_title(@section, @part) %>
<% is_reading = @section.section_type == "reading" %>
<% form_id = "mock-answer-form-#{@part.id}" %>

<div
  class="<%= is_reading ? 'h-screen flex flex-col overflow-hidden' : 'min-h-screen' %> bg-white"
  data-controller="exam-progress mock-timer"
  data-exam-progress-total-count-value="<%= @total_count %>"
  data-mock-timer-seconds-value="<%= mock_section_time_limit_seconds(@section.section_type) %>"
>
  <%# ===== Header ===== %>
  <header class="flex-shrink-0 flex items-stretch h-16 border-b-[3px] border-[#1a1b4b] bg-white sticky top-0 z-50 font-sans">
    <%# Left: section title + timer %>
    <div class="flex items-center gap-4 px-6 w-1/3 min-w-0">
      <h1 class="text-[11px] font-bold tracking-[0.12em] text-gray-800 uppercase whitespace-nowrap truncate font-serif">
        <%= set_title %>
      </h1>
      <span
        class="text-[15px] font-bold text-gray-700 tracking-wider font-mono flex-shrink-0"
        data-mock-timer-target="display"
      >
        <%= mock_section_time_limit_display(@section.section_type) %>
      </span>
    </div>

    <%# Center: progress indicator %>
    <div class="flex flex-col items-center justify-center border-l border-r border-gray-200 w-1/3 px-4">
      <div class="text-xs text-gray-600 mb-1">
        回答済み :
        <span class="text-gray-800 font-medium" data-exam-progress-target="answeredCount"><%= @answered_count %></span>/<%= @total_count %>問
      </div>
      <div class="flex flex-wrap justify-center gap-1 w-full max-w-[250px]">
        <% @questions.each do |question| %>
          <div
            class="w-3 h-1 bg-gray-300"
            data-exam-progress-target="indicator"
            data-question-id="<%= question.id %>"
          ></div>
        <% end %>
      </div>
    </div>

    <%# Right: 中断ボタン + submit button %>
    <div class="flex items-center justify-end px-6 gap-4 w-1/3 text-sm">
      <button type="button"
              data-action="exam-progress#openModal"
              class="px-5 py-2 border border-gray-300 hover:bg-gray-50 transition-colors text-gray-700">
        試験を中断する
      </button>
      <%= button_tag @submit_label,
            type: :submit,
            form: form_id,
            data: { "exam-progress-target": "submitButton" },
            class: "px-8 py-2 bg-[#1a1b4b] text-white hover:bg-blue-900 transition-colors cursor-pointer" %>
    </div>
  </header>

  <%# ===== Interrupt Modal ===== %>
  <div
    class="hidden fixed inset-0 bg-black/70 flex items-center justify-center p-4 z-50 font-serif"
    data-exam-progress-target="interruptModal"
  >
    <div class="bg-white w-full max-w-6xl px-8 py-16 md:py-20 shadow-2xl">
      <h2 class="text-xl md:text-2xl font-bold text-center text-gray-900 mb-6 tracking-widest">
        警告: 試験の中断
      </h2>
      <p class="text-sm md:text-base text-gray-500 text-center mb-12 leading-relaxed">
        現在、試験を中断しようとしています。この操作を行うと現在のセッションは完了扱いとなり、未回答の問題は無効となります。本当によろしいですか？
      </p>
      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <button
          type="button"
          data-action="exam-progress#closeModal"
          class="w-full sm:w-1/2 py-3.5 px-4 bg-[#f8f9fa] border border-gray-200 text-gray-700 font-medium hover:bg-gray-100 transition-colors duration-200 tracking-wider text-sm"
        >
          試験に戻る
        </button>
        <%= link_to "中断を確定する", mocks_path,
              class: "w-full sm:w-1/2 py-3.5 px-4 bg-[#081f5c] text-white font-medium hover:bg-[#05143e] transition-colors duration-200 tracking-wider text-sm text-center" %>
      </div>
    </div>
  </div>

  <%# ===== Form + Content ===== %>
  <%= form_with(
    url: submit_part_mock_path(@mock, section_id: @section.id, part_id: @part.id, attempt_id: @attempt.id),
    method: :post,
    id: form_id,
    class: is_reading ? "flex-1 flex flex-col overflow-hidden" : ""
  ) do %>
    <% if @section.section_type == "listening" && @part.part_type == "part_a" %>
      <%= render "shared/exam/layouts/listening_part_a", questions: @questions, single_use_audio: true %>

    <% elsif @section.section_type == "listening" %>
      <%= render "shared/exam/layouts/listening_part_bc",
            question_sets: @question_sets,
            part_label: mock_part_label(@part.part_type)&.upcase,
            single_use_audio: true %>

    <% elsif @section.section_type == "structure" %>
      <%= render "shared/exam/layouts/structure", questions: @questions, part_label: mock_part_label(@part.part_type)&.upcase %>

    <% elsif @section.section_type == "reading" %>
      <%= render "shared/exam/layouts/reading", question_sets: @question_sets, tabbed: true %>
    <% end %>
  <% end %>
</div>
