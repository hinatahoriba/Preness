<% set_title = mock_section_part_title(@section, @part) %>
<% is_reading = @section.section_type == "reading" %>
<% form_id = "mock-answer-form-#{@part.id}" %>

<div
  class="<%= is_reading ? 'h-screen flex flex-col overflow-hidden' : 'min-h-screen' %> bg-white"
  data-controller="mock-progress mock-timer"
  data-mock-progress-total-count-value="<%= @total_count %>"
  data-mock-timer-seconds-value="<%= mock_section_time_limit_seconds(@section.section_type) %>"
>
  <%# ===== Header ===== %>
  <header class="flex-shrink-0 flex items-stretch h-16 border-b-[3px] border-[#1a1b4b] bg-white sticky top-0 z-50 font-sans">
    <%# Left: section title + timer %>
    <div class="flex items-center gap-4 px-6 w-1/3 min-w-0">
      <h1 class="text-[11px] font-bold tracking-[0.12em] text-gray-800 uppercase whitespace-nowrap truncate font-serif">
        <%= set_title %>
      </h1>
      <span
        class="text-[15px] font-bold text-gray-700 tracking-wider font-mono flex-shrink-0"
        data-mock-timer-target="display"
      >
        <%= mock_section_time_limit_display(@section.section_type) %>
      </span>
    </div>

    <%# Center: progress indicator %>
    <div class="flex flex-col items-center justify-center border-l border-r border-gray-200 w-1/3 px-4">
      <div class="text-xs text-gray-600 mb-1">
        回答済み :
        <span class="text-gray-800 font-medium" data-mock-progress-target="answeredCount"><%= @answered_count %></span>/<%= @total_count %>問
      </div>
      <div class="flex flex-wrap justify-center gap-1 w-full max-w-[250px]">
        <% @questions.each do |question| %>
          <div
            class="w-3 h-1 bg-gray-300"
            data-mock-progress-target="indicator"
            data-question-id="<%= question.id %>"
          ></div>
        <% end %>
      </div>
    </div>

    <%# Right: 中断ボタン + submit button %>
    <div class="flex items-center justify-end px-6 gap-4 w-1/3 text-sm">
      <%= link_to "試験を中断する", mocks_path,
            data: { turbo_confirm: "試験を中断しますか？回答内容は保存されません。" },
            class: "px-5 py-2 border border-gray-300 hover:bg-gray-50 transition-colors text-gray-700" %>
      <%= button_tag mock_has_next_part?(@mock, @part) ? "次のパートへ進む" : "採点して結果を見る",
            type: :submit,
            form: form_id,
            disabled: true,
            data: { "mock-progress-target": "submitButton" },
            class: "px-8 py-2 bg-[#1a1b4b] text-white hover:bg-blue-900 transition-colors disabled:opacity-40 disabled:cursor-not-allowed cursor-pointer" %>
    </div>
  </header>

  <%# ===== Form + Content ===== %>
  <%= form_with(
    url: submit_part_mock_path(@mock, section_id: @section.id, part_id: @part.id, attempt_id: @attempt.id),
    method: :post,
    id: form_id,
    class: is_reading ? "flex-1 flex flex-col overflow-hidden" : ""
  ) do %>
    <% if @section.section_type == "listening" && @part.part_type == "part_a" %>
      <%= render "mocks/listening_part_a", questions: @questions %>

    <% elsif @section.section_type == "listening" %>
      <%= render "mocks/listening_part_bc",
            question_sets: @part.question_sets.order(:display_order),
            part_label: mock_part_label(@part.part_type)&.upcase %>

    <% elsif @section.section_type == "structure" %>
      <%= render "mocks/structure", questions: @questions %>

    <% elsif @section.section_type == "reading" %>
      <%= render "mocks/reading", question_sets: @part.question_sets.order(:display_order) %>
    <% end %>
  <% end %>
</div>
