<% content_for :body_class, "bg-[#f9fafb] text-[#374151] h-screen" %>

<div class="flex h-full">
  <%# サイドバー %>
  <aside class="w-60 bg-white border-r border-gray-100 flex flex-col h-full">
    <div class="p-6">
      <h1 class="text-xl font-black italic text-gray-800 tracking-tighter text-center">Preness</h1>
    </div>

    <nav class="flex-1 px-3 space-y-1">
      <%= link_to mypage_path, class: "flex items-center space-x-3 text-gray-400 hover:bg-gray-50 px-4 py-2.5 rounded-xl font-medium transition" do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"></path></svg>
        <span class="text-sm">ダッシュボード</span>
      <% end %>
<%# 模擬試験へのリンクは削除 %>

      <%= link_to "#", class: "flex items-center space-x-3 text-gray-400 hover:bg-gray-50 px-4 py-2.5 rounded-xl font-medium transition" do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
        <span class="text-sm">学習履歴</span>
      <% end %>

      <%= link_to edit_user_registration_path, class: "flex items-center space-x-3 text-gray-400 hover:bg-gray-50 px-4 py-2.5 rounded-xl font-medium transition" do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
        <span class="text-sm">アカウント設定</span>
      <% end %>

      <%= link_to "#", class: "flex items-center space-x-3 text-gray-400 hover:bg-gray-50 px-4 py-2.5 rounded-xl font-medium transition" do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
        <span class="text-sm">サポート・規約</span>
      <% end %>
    </nav>

    <div class="p-6 border-t border-gray-50">
      <%= link_to destroy_user_session_path, data: { turbo_method: :delete }, class: "flex items-center space-x-3 text-gray-400 hover:text-red-500 transition text-sm font-medium w-full px-4" do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path></svg>
        <span>ログアウト</span>
      <% end %>
    </div>
  </aside>

  <%# メインコンテンツ %>
  <main class="flex-1 p-8 overflow-y-auto">
    <header class="flex justify-between items-center mb-8">
      <div>
        <h2 class="text-2xl font-bold tracking-tight text-gray-900 leading-none">模擬試験一覧</h2>
        <p class="text-gray-400 text-sm mt-2">実際の試験形式で実力を測りましょう。</p>
      </div>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% @mocks.each do |mock| %>
        <% attempt = @attempts_by_mock_id[mock.id] %>
        <div class="bg-white border border-gray-100 rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-shadow flex flex-col h-full">
          <div class="p-6 flex-1">
            <div class="flex justify-between items-start mb-4">
              <div class="w-10 h-10 bg-teal-50 rounded-lg flex items-center justify-center text-[#34a0a4]">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
              </div>
              <% if attempt&.completed_at %>
                <span class="px-2.5 py-1 bg-green-50 text-green-600 text-xs font-bold rounded-full">完了</span>
              <% elsif attempt %>
                <span class="px-2.5 py-1 bg-blue-50 text-blue-600 text-xs font-bold rounded-full">実施中</span>
              <% else %>
                <span class="px-2.5 py-1 bg-gray-50 text-gray-400 text-xs font-bold rounded-full">未受験</span>
              <% end %>
            </div>

            <h3 class="text-lg font-bold text-gray-800 mb-2"><%= mock.title %></h3>
            <p class="text-xs text-gray-400 mb-4">TOEFL ITP 形式 (Listening, Structure, Reading)</p>

            <% if attempt&.completed_at %>
              <div class="text-xs text-gray-500 space-y-1">
                <p>受験日: <%= attempt.completed_at.strftime("%Y年%m月%d日") %></p>
              </div>
            <% end %>
          </div>

          <div class="p-4 bg-gray-50/50 border-t border-gray-50 mt-auto">
            <% if attempt&.completed_at %>
              <%= link_to result_mock_path(mock, attempt_id: attempt.id), class: "w-full bg-white border border-gray-200 text-gray-700 hover:bg-gray-50 py-2.5 rounded-xl text-sm font-bold flex items-center justify-center space-x-2 transition shadow-sm" do %>
                <span>結果を確認する</span>
              <% end %>
            <% elsif attempt %>
              <%= link_to guideline_mock_path(mock), class: "w-full bg-[#34a0a4] hover:bg-[#2d8b8e] text-white py-2.5 rounded-xl text-sm font-bold flex items-center justify-center space-x-2 transition shadow-sm" do %>
                <span>続きから再開する</span>
                <span>→</span>
              <% end %>
            <% else %>
              <%= link_to guideline_mock_path(mock), class: "w-full bg-[#34a0a4] hover:bg-[#2d8b8e] text-white py-2.5 rounded-xl text-sm font-bold flex items-center justify-center space-x-2 transition shadow-sm" do %>
                <span>受験を開始する</span>
                <span>→</span>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </main>
</div>
