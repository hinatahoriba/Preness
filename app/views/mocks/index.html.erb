<% content_for :body_class, "bg-[#f9fafb] text-[#374151] min-h-screen" %>

<main class="max-w-7xl mx-auto p-8 overflow-y-auto">
  <header class="flex justify-between items-center mb-12">
    <div>
      <div class="flex items-center space-x-4 mb-4">
        <%= link_to mypage_path, class: "text-[#34a0a4] hover:text-[#2d8b8e] transition flex items-center space-x-1" do %>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
          <span class="text-sm font-bold">ダッシュボードへ戻る</span>
        <% end %>
      </div>
      <h2 class="text-3xl font-extrabold tracking-tight text-gray-900 leading-none">模擬試験一覧</h2>
      <p class="text-gray-400 text-sm mt-3">実際の試験形式で実力を測りましょう。</p>
    </div>
  </header>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
    <% @index_presenter.cards.each do |card| %>
      <% mock = card[:mock] %>
      <div class="bg-white border border-gray-100 rounded-3xl overflow-hidden shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 flex flex-col h-full group">
        <div class="p-8 flex-1">
          <div class="flex justify-between items-start mb-6">
            <div class="w-12 h-12 bg-teal-50 rounded-2xl flex items-center justify-center text-[#34a0a4] group-hover:scale-110 transition-transform duration-300">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
            </div>
            <span class="px-4 py-1.5 text-xs font-bold rounded-full <%= card[:badge][:class] %>"><%= card[:badge][:label] %></span>
          </div>

          <h3 class="text-xl font-bold text-gray-800 mb-3 group-hover:text-[#34a0a4] transition-colors"><%= mock.title %></h3>
          <p class="text-sm text-gray-400 mb-6 leading-relaxed">TOEFL ITP 形式<br>(Listening, Structure, Reading)</p>

          <% if card[:attempt_date].present? %>
            <div class="text-xs text-gray-500 bg-gray-50 p-3 rounded-xl border border-gray-100">
              <p class="font-medium">受験日: <span class="text-gray-700"><%= card[:attempt_date] %></span></p>
            </div>
          <% elsif card[:interrupted] %>
            <div class="text-xs text-red-700 bg-red-50 p-3 rounded-xl border border-red-100">
              <p class="font-medium">途中で中断されたため、再開できません。</p>
            </div>
          <% end %>
        </div>

        <div class="p-6 bg-white border-t border-gray-50 mt-auto">
          <% case card[:action][:type] %>
          <% when :purchase %>
            <%= button_to checkouts_path(mock_id: mock.id),
                  method: :post,
                  data: { turbo: false },
                  class: card[:action][:class] do %>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z"></path></svg>
              <span><%= card[:action][:label] %></span>
            <% end %>
          <% when :link %>
            <%= link_to card[:action][:path], class: card[:action][:class] do %>
              <span><%= card[:action][:label] %></span>
              <% if card[:action][:label] == "受験を開始する" %>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
              <% end %>
            <% end %>
          <% else %>
            <div class="<%= card[:action][:class] %>">
              <span><%= card[:action][:label] %></span>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</main>
