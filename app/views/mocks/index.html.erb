<% content_for :body_class, "bg-slate-50 text-slate-800 min-h-screen" %>

<main class="max-w-4xl w-full mx-auto px-4 md:px-6 py-8 md:py-12">

  <%# 説明バナー %>
  <div class="bg-white rounded-2xl p-5 md:p-6 shadow-sm border border-gray-100 mb-8 flex gap-4 items-start">
    <div class="w-10 h-10 rounded-full bg-[#fff1e5] text-[#e68e4a] flex items-center justify-center shrink-0 mt-0.5">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
    </div>
    <div>
      <h1 class="text-lg font-bold text-[#2a304f] mb-1">TOEFL ITP 模擬試験</h1>
      <p class="text-sm text-gray-500 leading-relaxed">
        本番と同形式（全140問 / 約115分）のオンライン模試です。
      </p>
    </div>
  </div>

  <h2 class="text-sm font-bold text-gray-400 mb-4 px-2 tracking-wider">現在利用できる模擬試験</h2>

  <div class="space-y-4">
    <% @index_presenter.cards.each do |card| %>
      <% mock = card[:mock] %>

      <% if card[:action][:type] == :disabled %>
        <%# 中断カード %>
        <div class="bg-slate-50 rounded-2xl p-5 border border-gray-200 opacity-60 flex justify-between items-center">
          <div>
            <h3 class="text-base font-bold text-gray-500 line-through decoration-gray-400"><%= mock.title %></h3>
          </div>
          <span class="text-xs font-bold text-gray-500 bg-gray-200 px-3 py-1.5 rounded-md">中断</span>
        </div>

      <% elsif card[:attempt_date].present? %>
        <%# 受験完了カード %>
        <div class="bg-slate-50 rounded-2xl p-5 border border-gray-200 opacity-60 flex justify-between items-center">
          <div>
            <h3 class="text-base font-bold text-gray-500 line-through decoration-gray-400"><%= mock.title %></h3>
          </div>
          <span class="text-xs font-bold text-gray-500 bg-gray-200 px-3 py-1.5 rounded-md">受験完了</span>
        </div>

      <% elsif card[:action][:type] == :link && card[:action][:label] == "受験を開始する" %>
        <%# 購入済み・未受験カード（ハイライト） %>
        <div class="bg-white rounded-2xl p-5 border-2 border-[#e68e4a] shadow-md shadow-orange-500/10 flex flex-col md:flex-row md:items-center justify-between gap-4 relative overflow-hidden">
          <div class="absolute -right-4 -top-4 w-24 h-24 bg-[#fff1e5] rounded-full opacity-50 z-0 pointer-events-none"></div>
          <div class="relative z-10">
            <span class="text-[10px] font-bold text-[#e68e4a] bg-[#fff1e5] px-2 py-0.5 rounded mb-2 inline-block">購入済み</span>
            <h3 class="text-xl font-bold text-[#2a304f]"><%= mock.title %></h3>
            <p class="text-sm text-gray-500 mt-1">準備ができたら開始してください</p>
          </div>
          <%= link_to card[:action][:path], class: "relative z-10 w-full md:w-auto bg-[#e68e4a] hover:bg-[#d67b36] text-white font-bold py-3.5 px-8 rounded-xl transition-all shadow-md shadow-orange-500/20 active:scale-95 flex items-center justify-center gap-2" do %>
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM9.555 7.168A1 1 0 008 8v4a1 1 0 001.555.832l3-2a1 1 0 000-1.664l-3-2z" clip-rule="evenodd"></path></svg>
            受験を開始する
          <% end %>
        </div>

      <% elsif card[:action][:type] == :purchase %>
        <%# 未購入カード %>
        <div class="bg-white rounded-2xl p-5 border border-gray-200 hover:border-orange-200 shadow-sm transition-colors flex flex-col md:flex-row md:items-center justify-between gap-4">
          <div>
            <h3 class="text-lg font-bold text-[#2a304f]"><%= mock.title %></h3>
            <p class="text-sm text-gray-500 mt-1 font-medium">TOEFL ITP 形式</p>
          </div>
          <%= button_to checkouts_path(mock_id: mock.id),
                method: :post,
                data: { turbo: false },
                class: "w-full md:w-auto bg-white border-2 border-[#e68e4a] text-[#e68e4a] hover:bg-[#fff1e5] font-bold py-3 px-8 rounded-xl transition-all active:scale-95 flex items-center justify-center gap-2" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z"></path></svg>
            <span><%= card[:action][:label] %></span>
          <% end %>
        </div>

      <% else %>
        <%# その他（結果確認など） %>
        <div class="bg-white rounded-2xl p-5 border border-gray-200 hover:border-orange-200 shadow-sm transition-colors flex flex-col md:flex-row md:items-center justify-between gap-4">
          <div>
            <h3 class="text-lg font-bold text-[#2a304f]"><%= mock.title %></h3>
            <p class="text-sm text-gray-500 mt-1">TOEFL ITP 形式</p>
          </div>
          <%= link_to card[:action][:path], class: "w-full md:w-auto bg-white border-2 border-[#e68e4a] text-[#e68e4a] hover:bg-[#fff1e5] font-bold py-3 px-8 rounded-xl transition-all active:scale-95 flex items-center justify-center gap-2" do %>
            <span><%= card[:action][:label] %></span>
          <% end %>
        </div>
      <% end %>
    <% end %>
  </div>

</main>
