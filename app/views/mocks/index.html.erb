<% content_for :body_class, "bg-[#f9fafb] text-[#374151] min-h-screen" %>

<main class="max-w-7xl mx-auto p-8 overflow-y-auto">
  <header class="flex justify-between items-center mb-12">
    <div>
      <div class="flex items-center space-x-4 mb-4">
        <%= link_to mypage_path, class: "text-[#34a0a4] hover:text-[#2d8b8e] transition flex items-center space-x-1" do %>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
          <span class="text-sm font-bold">ダッシュボードへ戻る</span>
        <% end %>
      </div>
      <h2 class="text-3xl font-extrabold tracking-tight text-gray-900 leading-none">模擬試験一覧</h2>
      <p class="text-gray-400 text-sm mt-3">実際の試験形式で実力を測りましょう。</p>
    </div>
  </header>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
    <% @mocks.each do |mock| %>
      <% attempt = @attempts_by_mock_id[mock.id] %>
      <div class="bg-white border border-gray-100 rounded-3xl overflow-hidden shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 flex flex-col h-full group">
        <div class="p-8 flex-1">
          <div class="flex justify-between items-start mb-6">
            <div class="w-12 h-12 bg-teal-50 rounded-2xl flex items-center justify-center text-[#34a0a4] group-hover:scale-110 transition-transform duration-300">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
            </div>
            <% if attempt&.completed_at %>
              <span class="px-4 py-1.5 bg-green-50 text-green-600 text-xs font-bold rounded-full">完了</span>
            <% elsif attempt %>
              <span class="px-4 py-1.5 bg-red-50 text-red-600 text-xs font-bold rounded-full">中断</span>
            <% else %>
              <span class="px-4 py-1.5 bg-gray-50 text-gray-400 text-xs font-bold rounded-full">未受験</span>
            <% end %>
          </div>

          <h3 class="text-xl font-bold text-gray-800 mb-3 group-hover:text-[#34a0a4] transition-colors"><%= mock.title %></h3>
          <p class="text-sm text-gray-400 mb-6 leading-relaxed">TOEFL ITP 形式<br>(Listening, Structure, Reading)</p>

          <% if attempt&.completed_at %>
            <div class="text-xs text-gray-500 bg-gray-50 p-3 rounded-xl border border-gray-100">
              <p class="font-medium">受験日: <span class="text-gray-700"><%= attempt.completed_at.strftime("%Y年%m月%d日") %></span></p>
            </div>
          <% elsif attempt %>
            <div class="text-xs text-red-700 bg-red-50 p-3 rounded-xl border border-red-100">
              <p class="font-medium">途中で中断されたため、再開できません。</p>
            </div>
          <% end %>
        </div>

        <div class="p-6 bg-white border-t border-gray-50 mt-auto">
          <% if attempt&.completed_at %>
            <%= link_to result_mock_path(mock, attempt_id: attempt.id), class: "w-full bg-white border-2 border-gray-100 text-gray-700 hover:border-[#34a0a4] hover:text-[#34a0a4] py-3 rounded-2xl text-sm font-bold flex items-center justify-center space-x-2 transition-all shadow-sm" do %>
              <span>結果を確認する</span>
            <% end %>
          <% elsif attempt %>
            <div class="w-full bg-gray-100 text-gray-500 py-3 rounded-2xl text-sm font-bold flex items-center justify-center space-x-2 cursor-not-allowed select-none">
              <span>中断（再開できません）</span>
            </div>
          <% elsif @purchased_mock_ids.include?(mock.id) %>
            <%= link_to guideline_mock_path(mock), class: "w-full bg-[#34a0a4] hover:bg-[#2d8b8e] text-white py-3 rounded-2xl text-sm font-bold flex items-center justify-center space-x-2 transition-all shadow-lg hover:shadow-[#34a0a4]/30" do %>
              <span>受験を開始する</span>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
            <% end %>
          <% else %>
            <%= button_to purchases_path(mock_id: mock.id), data: { turbo: false }, class: "w-full bg-indigo-600 hover:bg-indigo-700 text-white py-3 rounded-2xl text-sm font-bold flex items-center justify-center space-x-2 transition-all shadow-lg hover:shadow-indigo-600/30" do %>
              <span>購入する</span>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</main>
