<!DOCTYPE html>
<html lang="ja">
<body style="font-family: sans-serif; color: #374151; background: #f9fafb; padding: 32px;">
  <div style="max-width: 560px; margin: 0 auto; background: #fff; border-radius: 8px; border: 1px solid #e5e7eb; padding: 32px;">
    <h2 style="font-size: 18px; font-weight: bold; margin-bottom: 24px; color: #111827;">新しいお問い合わせが届きました</h2>

    <table style="width: 100%; border-collapse: collapse; font-size: 14px;">
      <tr style="border-bottom: 1px solid #f3f4f6;">
        <th style="text-align: left; padding: 10px 8px; width: 120px; color: #6b7280; font-weight: 600;">お名前</th>
        <td style="padding: 10px 8px;"><%= @name %></td>
      </tr>
      <tr style="border-bottom: 1px solid #f3f4f6;">
        <th style="text-align: left; padding: 10px 8px; color: #6b7280; font-weight: 600;">メールアドレス</th>
        <td style="padding: 10px 8px;"><a href="mailto:<%= @email %>" style="color: #479387;"><%= @email %></a></td>
      </tr>
      <tr style="border-bottom: 1px solid #f3f4f6;">
        <th style="text-align: left; padding: 10px 8px; color: #6b7280; font-weight: 600;">件名</th>
        <td style="padding: 10px 8px;"><%= @subject %></td>
      </tr>
      <tr>
        <th style="text-align: left; padding: 10px 8px; vertical-align: top; color: #6b7280; font-weight: 600;">内容</th>
        <td style="padding: 10px 8px; white-space: pre-wrap;"><%= @body %></td>
      </tr>
    </table>
  </div>
</body>
</html>
