<%# Locals:
#   question_sets (Array<QuestionSet>)
#   part_label (String)
#   single_use_audio (Boolean)
%>
<div
  class="pb-16 max-w-5xl mx-auto px-8"
  data-controller="exam-audio-player"
  data-exam-audio-player-single-use-value="<%= local_assigns.fetch(:single_use_audio, false) %>"
>
  <main class="pt-10">
    <h2 class="text-xl font-bold tracking-wide pb-2 border-b border-black mb-6 font-serif text-gray-800">
      <%= local_assigns[:part_label] || "PART B" %>
    </h2>
    <p class="text-[15px] leading-relaxed text-gray-800 mb-12 font-serif">
      <span class="font-bold underline decoration-1 underline-offset-2">Directions:</span>
      <% if (local_assigns[:part_label] || "PART B").include?("C") %>
        In Part C, you will hear several talks. After each talk, you will hear several questions. The talks and questions will not be repeated. After you hear a question, read the four possible answers and choose the best answer.
      <% else %>
        In Part B you will hear longer conversations. After each conversation, you will be asked some questions. The conversations and questions will be spoken just once. They will not be written out for you, so you will have to listen carefully in order to understand and remember what the speaker says.
      <% end %>
    </p>

    <% q_offset = 0 %>
    <% question_sets.each_with_index do |question_set, set_index| %>
      <% unless set_index == 0 %>
        <hr class="border-t border-gray-300 mb-16">
      <% end %>
      <div class="mb-16">
        <% if question_set.conversation_audio_url.present? %>
          <% audio_label = question_sets.size > 1 ? "CONVERSATION AUDIO #{set_index + 1}" : "CONVERSATION AUDIO" %>
          <% audio_status = question_sets.size > 1 ? "Click to play conversation for Questions #{q_offset + 1}–#{q_offset + question_set.questions.count}" : "Click to play conversation" %>
          <%= render "shared/exam/audio_player",
                url: question_set.conversation_audio_url,
                label: audio_label,
                status_text: audio_status %>
        <% end %>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-x-16 gap-y-12">
          <% question_set.questions.order(:display_order).each_with_index do |question, question_index| %>
            <div class="question-block">
              <% if question.question_audio_url.present? %>
                <%= render "shared/exam/audio_player",
                      url: question.question_audio_url,
                      label: "QUESTION AUDIO",
                      status_text: "Click to play question",
                      hide_ui: true %>
              <% end %>
              <%= render "shared/exam/question_item", question: question, index: q_offset + question_index %>
            </div>
          <% end %>
        </div>
      </div>
      <% q_offset += question_set.questions.count %>
    <% end %>
  </main>
</div>
