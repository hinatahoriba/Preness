<%# Locals:
#   question (Question)
#   review   (ExamSessions::QuestionReviewPresenter)
%>
<div class="px-8 py-6 space-y-7 overflow-y-auto">
  <% if review.audio_url.present? %>
    <div>
      <h3 class="text-xs font-bold text-gray-500 mb-3">音声</h3>
      <div class="bg-gray-50 p-4 rounded border border-gray-200">
        <audio controls src="<%= review.audio_url %>" class="w-full h-10 outline-none"></audio>
      </div>
    </div>
  <% end %>

  <% if review.passage.present? %>
    <div>
      <h3 class="text-xs font-bold text-gray-500 mb-3"><%= review.context_title %></h3>
      <div class="bg-[#F8F9FA] border-l-[3px] border-[#6b7280] py-4 px-5">
        <p class="font-mono text-[14px] text-gray-800 tracking-tight whitespace-pre-wrap leading-relaxed"><%= review.passage %></p>
      </div>
    </div>
  <% elsif review.scripts.present? %>
    <div>
      <h3 class="text-xs font-bold text-gray-500 mb-3">リスニング原稿</h3>
      <div class="bg-[#F8F9FA] border-l-[3px] border-[#6b7280] py-4 px-5 space-y-2">
        <% review.scripts.each do |script| %>
          <p class="font-mono text-[14px] text-gray-800 leading-relaxed">
            <span class="font-bold uppercase text-gray-500 mr-2 text-[12px]"><%= script["speaker"] || script[:speaker] %>:</span>
            <%= script["text"] || script[:text] %>
          </p>
        <% end %>
      </div>
    </div>
  <% end %>

  <div>
    <h3 class="text-xs font-bold text-gray-500 mb-3">問題文</h3>
    <div class="bg-[#F8F9FA] border-l-[3px] border-[#2C3358] py-4 px-5">
      <p class="font-mono text-[15px] text-gray-800 tracking-tight"><%= question.question_text %></p>
    </div>
  </div>

  <div>
    <h3 class="text-xs font-bold text-gray-500 mb-3">選択肢</h3>
    <div class="space-y-3">
      <% review.choices.each do |choice| %>
        <% if choice[:correct] %>
          <div class="bg-[#E6F9EA] border border-[#4CAF50] rounded-sm py-3 px-5">
            <p class="font-mono text-[14px] text-gray-800"><span class="font-bold mr-1"><%= choice[:choice] %>.</span> <%= choice[:text] %></p>
          </div>
        <% elsif choice[:selected] %>
          <div class="bg-[#EDF1F7] border border-[#2C3358] rounded-sm py-3 px-5">
            <p class="font-mono text-[14px] text-gray-800"><span class="font-bold mr-1"><%= choice[:choice] %>.</span> <%= choice[:text] %></p>
          </div>
        <% else %>
          <div class="border border-gray-200 rounded-sm py-3 px-5">
            <p class="font-mono text-[14px] text-gray-800"><span class="font-bold mr-1"><%= choice[:choice] %>.</span> <%= choice[:text] %></p>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>

  <div class="flex gap-28 pb-2">
    <div>
      <h3 class="text-[13px] font-bold text-gray-500 mb-2">あなたの解答</h3>
      <p class="font-bold <%= review.correct? ? 'text-[#2E7D32]' : 'text-red-600' %> text-sm">
        <%= review.selected_choice_display == "-" ? "未回答" : review.selected_choice_display %>
      </p>
    </div>
    <div>
      <h3 class="text-[13px] font-bold text-gray-500 mb-2">正解</h3>
      <p class="font-bold text-[#2E7D32] text-sm"><%= review.correct_choice.upcase %></p>
    </div>
  </div>

  <% if review.wrong_reason.present? %>
    <div>
      <h3 class="text-xs font-bold text-gray-500 mb-3">間違えた理由</h3>
      <div class="bg-[#FFFCE8] border-l-[3px] border-red-400 py-4 px-5">
        <p class="font-mono text-[14px] text-gray-800 leading-relaxed whitespace-pre-line"><%= review.wrong_reason %></p>
      </div>
    </div>
  <% end %>

  <div>
    <h3 class="text-xs font-bold text-gray-500 mb-3">解説</h3>
    <div class="bg-[#FFFCE8] border-l-[3px] border-[#8D6E63] py-4 px-5">
      <p class="font-mono text-[14px] text-gray-800 leading-relaxed whitespace-pre-line"><%= review.explanation_text %></p>
    </div>
  </div>
</div>
