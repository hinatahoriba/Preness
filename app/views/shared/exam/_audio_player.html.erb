<%# Locals:
#   url         (String)  – audio src
#   label       (String)  – e.g. "LISTENING AUDIO" or "LISTENING AUDIO 1"
#   status_text (String)  – e.g. "Click to play conversation"
#   compact     (Boolean) – true: Part A style (small), false: Part BC style (large)
%>
<% compact = local_assigns.fetch(:compact, false) %>
<% outer_cls = compact \
     ? "bg-[#f4f5f7] border border-gray-200 p-3.5 mb-4 flex items-center h-20" \
     : "bg-[#f4f6f8] border border-gray-200 border-l-4 border-l-[#0f2361] p-5 flex items-center gap-5 mb-10 shadow-sm" %>
<% btn_cls = compact \
     ? "w-[44px] h-[44px] bg-[#1a1b4b] flex-shrink-0 flex items-center justify-center hover:bg-blue-900" \
     : "w-14 h-14 bg-[#0f2361] flex justify-center items-center rounded-sm flex-shrink-0 hover:bg-[#0a1845]" %>
<% content_cls = compact ? "ml-4 font-sans flex flex-col justify-center" : "flex flex-col" %>
<% label_cls = compact ? "text-[#1a1b4b] font-bold text-sm tracking-wider" : "text-[#0f2361] font-bold text-xs tracking-widest font-sans" %>
<% status_cls = compact ? "font-mono" : "font-sans" %>
<% hide_ui = local_assigns.fetch(:hide_ui, false) %>
<% status_text = local_assigns.fetch(:status_text, "Click to play audio") %>

<div class="<%= outer_cls %> <%= 'hidden' if hide_ui %>">
  <button
    type="button"
    class="<%= btn_cls %> transition cursor-pointer disabled:cursor-not-allowed"
    data-exam-audio-player-target="playButton"
    data-action="click->exam-audio-player#playAudio"
  >
    <% if compact %>
      <svg class="w-5 h-5 text-white ml-1" fill="currentColor" viewBox="0 0 20 20">
        <path d="M4 4l12 6-12 6V4z"/>
      </svg>
    <% else %>
      <svg class="w-6 h-6 text-white ml-1" fill="currentColor" viewBox="0 0 24 24">
        <path d="M8 5v14l11-7z"/>
      </svg>
    <% end %>
  </button>

  <div class="<%= content_cls %>">
    <div class="flex items-center gap-2 mb-1 <%= label_cls %>">
      <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15.536 8.464a5 5 0 010 7.072m2.828-9.9a9 9 0 010 12.728M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15z"/>
      </svg>
      <%= label %>
    </div>
    <span
      class="text-[10px] text-gray-500 tracking-widest uppercase <%= status_cls %>"
      data-exam-audio-player-target="statusLabel"
    ><%= status_text %></span>
  </div>

  <audio src="<%= url %>" class="hidden" data-exam-audio-player-target="audio"></audio>
</div>
