<main class="flex-grow max-w-4xl w-full mx-auto px-4 md:px-6 py-8 md:py-12 animate-fadeInUp">
  <div class="space-y-8 animate-fade-in pb-16 max-w-4xl mx-auto">

    <div class="mb-8">
      <h1 class="text-3xl font-black text-[#1B3B69] tracking-tight">
        受験履歴
      </h1>

      <p class="text-gray-400 mt-2 font-medium">
        これまでの模擬試験の結果を確認できます。
      </p>
    </div>

    <% if @completed_attempts.any? %>
      <div class="space-y-4">

        <% @completed_attempts.each do |attempt| %>
          <% report = attempt.analysis_report %>
          <% is_diagnostic = attempt.mockable_type == "Diagnostic" %>

          <% result_path =
            is_diagnostic ?
            result_diagnostic_path(attempt.mockable, attempt_id: attempt.id) :
            result_mock_path(attempt.mockable, attempt_id: attempt.id)
          %>

          <% report_path =
            is_diagnostic ?
            report_diagnostic_path(attempt.mockable, attempt_id: attempt.id) :
            report_mock_path(attempt.mockable, attempt_id: attempt.id)
          %>

          <div class="bg-white rounded-2xl p-4 border border-gray-100 shadow-sm flex flex-row items-center justify-between gap-2 lg:gap-4 flex-wrap md:flex-nowrap hover:shadow-md transition-shadow">

            <div class="flex flex-row items-center gap-4 lg:gap-8 flex-1 min-w-fit">
              <h3 class="text-lg font-black text-[#1B3B69] whitespace-nowrap">
                <%= attempt.mockable.title %>
              </h3>

              <span class="text-lg font-black text-[#1B3B69] whitespace-nowrap">
                スコア: <%= report&.total_score || "—" %>
              </span>
            </div>

            <div class="flex flex-row items-center gap-2 min-w-fit mt-3 md:mt-0 w-full md:w-auto justify-end">

              <%= link_to "回答/正誤を確認",
                result_path,
                class: "px-4 lg:px-6 py-2.5 bg-teal-light text-teal rounded-xl text-sm font-black hover:opacity-80 transition-all whitespace-nowrap text-center"
              %>

              <% if report && report.completed? %>
                <%= link_to "分析レポート",
                  report_path,
                  class: "px-4 lg:px-6 py-2.5 bg-brand-teal-light text-brand-teal rounded-xl text-sm font-black hover:bg-teal/10 transition-all whitespace-nowrap text-center"
                %>
              <% else %>
                <button
                  class="px-4 lg:px-6 py-2.5 bg-teal-light text-teal rounded-xl text-sm font-black opacity-50 cursor-not-allowed whitespace-nowrap text-center"
                  disabled
                >
                  分析レポート
                </button>
              <% end %>

              <div class="ml-2 min-w-[100px] flex justify-center">
                <% if report && report.completed? %>
                  <span class="px-3 py-1 bg-green-50 text-green-600 rounded-full text-[11px] font-black border border-green-100">
                    分析完了
                  </span>

                <% elsif report && report.pending? %>
                  <span class="px-3 py-1 bg-blue-50 text-blue-600 rounded-full text-[11px] font-black border border-blue-100 animate-pulse">
                    分析中...
                  </span>

                <% else %>
                  <span class="px-3 py-1 bg-red-50 text-red-600 rounded-full text-[11px] font-black border border-red-100">
                    分析失敗
                  </span>
                <% end %>
              </div>

            </div>
          </div>
        <% end %>

      </div>

    <% else %>
      <div class="bg-white border border-dashed border-gray-200 rounded-[40px] p-16 text-center">

        <div class="w-16 h-16 bg-brand-teal-light rounded-2xl flex items-center justify-center mx-auto mb-5 text-brand-teal">
        </div>

        <h3 class="text-brand-navy font-black text-lg mb-2">
          受験履歴がありません
        </h3>

        <p class="text-gray-400 text-xs mb-8">
          実力診断または模擬試験を受験すると、ここに分析レポートが表示されます。
        </p>

        <div class="flex flex-col sm:flex-row justify-center gap-3 max-w-md mx-auto">

          <%= link_to "実力診断を受ける",
            diagnostics_path,
            class: "flex-1 bg-brand-orange-btn text-white px-6 py-3.5 rounded-2xl font-black text-sm hover:opacity-90 transition shadow-lg text-center"
          %>

          <%= link_to "模擬試験を受験する",
            mocks_path,
            class: "flex-1 bg-white border border-brand-teal text-brand-teal px-6 py-3.5 rounded-2xl font-black text-sm hover:bg-brand-teal-light transition text-center"
          %>

        </div>
      </div>
    <% end %>

  </div>
</main>
