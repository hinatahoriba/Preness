<% content_for :body_class, "bg-[#f9fafb] text-[#374151] h-screen" %>

<div class="flex h-full">
  <%= render 'shared/sidebar', active_page: :history %>

  <main class="flex-1 p-8 flex flex-col overflow-hidden">
    <header class="flex justify-between items-center mb-10">
      <div>
        <h2 class="text-2xl font-bold tracking-tight text-gray-900 leading-none">学習履歴</h2>
        <p class="text-gray-400 text-sm mt-2.5">これまでの模擬試験の結果と分析レポートを確認できます。</p>
      </div>
    </header>

    <div class="flex-1 overflow-y-auto pr-2 custom-scrollbar">
      <% if @completed_attempts.any? %>
        <div class="bg-white border border-gray-100 rounded-2xl shadow-sm overflow-hidden mb-8">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-gray-100 text-xs text-gray-400 font-semibold bg-gray-50/50">
                <th class="text-left px-8 py-4">模試名</th>
                <th class="text-left px-8 py-4">受験日</th>
                <th class="text-center px-8 py-4">トータルスコア</th>
                <th class="text-center px-8 py-4">ステータス</th>
                <th class="text-center px-8 py-4"></th>
              </tr>
            </thead>
            <tbody>
              <% @completed_attempts.each do |attempt| %>
                <% report = attempt.mock_analysis_report %>
                <tr class="border-b border-gray-100 last:border-0 hover:bg-gray-50 transition">
                  <td class="px-8 py-5 font-medium text-gray-800"><%= attempt.mockable.title %></td>
                  <td class="px-8 py-5 text-gray-500"><%= attempt.completed_at.strftime("%Y/%m/%d") %></td>
                  <td class="px-8 py-5 text-center">
                    <% if report&.completed? %>
                      <span class="text-lg font-bold text-[#1e3a5f]"><%= report.total_score %></span>
                      <span class="text-xs text-gray-400">/ 677</span>
                    <% else %>
                      <span class="text-gray-400">—</span>
                    <% end %>
                  </td>
                  <td class="px-8 py-5 text-center">
                    <% if report.nil? || report.pending? %>
                      <span class="inline-flex items-center gap-1.5 bg-amber-50 text-amber-600 text-[11px] font-bold px-3 py-1.5 rounded-full">
                        <svg class="w-3 h-3 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"></path></svg>
                        分析制作中
                      </span>
                    <% elsif report.completed? %>
                      <span class="inline-block bg-teal-50 text-[#34a0a4] text-[11px] font-bold px-3 py-1.5 rounded-full">✓ 完了</span>
                    <% else %>
                      <span class="inline-block bg-red-50 text-red-500 text-[11px] font-bold px-3 py-1.5 rounded-full">分析失敗</span>
                    <% end %>
                  </td>
                  <td class="px-8 py-5 text-center">
                    <% if report&.completed? %>
                      <%= link_to report_mock_path(attempt.mockable, attempt_id: attempt.id),
                            class: "inline-flex items-center px-4 py-2 bg-[#34a0a4] text-white text-xs font-bold rounded-lg hover:bg-[#2d8b8e] transition shadow-sm" do %>
                        <span>レポートを見る</span>
                      <% end %>
                    <% else %>
                      <%= link_to "試験結果を確認",
                            result_mock_path(attempt.mockable, attempt_id: attempt.id),
                            class: "text-xs font-semibold text-gray-400 hover:text-gray-600 transition" %>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="bg-white border border-dashed border-gray-200 rounded-3xl p-20 text-center">
          <div class="w-16 h-16 bg-gray-50 rounded-full flex items-center justify-center mx-auto mb-4 text-gray-300">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
          </div>
          <h3 class="text-gray-800 font-bold text-lg mb-2">履歴がありません</h3>
          <p class="text-gray-400 text-sm mb-8">模擬試験を受験すると、ここに分析レポートが表示されます。</p>
          <%= link_to "模擬試験を受験する", mocks_path, class: "inline-block bg-[#34a0a4] text-white px-8 py-3 rounded-xl font-bold hover:bg-[#2d8b8e] transition shadow-sm" %>
        </div>
      <% end %>
    </div>
  </main>
</div>

<style>
.custom-scrollbar::-webkit-scrollbar {
  width: 6px;
}
.custom-scrollbar::-webkit-scrollbar-track {
  background: transparent;
}
.custom-scrollbar::-webkit-scrollbar-thumb {
  background: #e2e8f0;
  border-radius: 10px;
}
.custom-scrollbar::-webkit-scrollbar-thumb:hover {
  background: #cbd5e1;
}
</style>
