<% content_for :head do %>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400&family=Barlow+Condensed:wght@600&family=Noto+Sans+JP:wght@500;700&display=swap" rel="stylesheet" />
<% end %>

<% content_for :body_class, "lp-page overflow-x-hidden text-dark-text" %>

<!-- ========== HEADER / NAV ========== -->
<header class="bg-biscay sticky top-0 z-50 shadow-md">
  <div class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
    <!-- Logo -->
    <div class="text-white font-bold text-xl tracking-wide flex items-center gap-2">
      <%= image_tag "logo.png", alt: "Preness", class: "h-10 object-contain" %>
    </div>

    <!-- Nav links (desktop) -->
    <nav class="hidden md:flex items-center gap-8 text-catskill text-sm">
      <a href="#" class="flex items-center gap-1 hover:text-white transition">
        Prenessについて <span class="text-xs">▾</span>
      </a>
      <a href="#" class="flex items-center gap-1 hover:text-white transition">
        その他 <span class="text-xs">▾</span>
      </a>
      <%= link_to new_user_session_path, class: "flex items-center gap-1 hover:text-white transition" do %>
        ログイン <span class="text-xs">▾</span>
      <% end %>
    </nav>

    <!-- CTA buttons -->
    <div class="flex items-center gap-3">
      <a href="#" class="hidden md:inline-block btn-outline text-xs py-2 px-5">無料実力診断へ</a>
      <a href="#" class="bg-eastern-blue text-white font-bold text-xs rounded py-2 px-5 hover:opacity-85 transition">お問い合わせ</a>
    </div>
  </div>
</header>

<!-- ========== HERO ========== -->
<section class="relative bg-[#c1ddff] py-20 overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 flex flex-col-reverse md:flex-row items-center gap-12">
    <!-- Text -->
    <div class="md:w-1/2 z-10">
      <p class="text-biscay font-bold text-sm mb-3 tracking-widest uppercase">Prenessで、学習環境を整えたい方へ</p>
      <h1 class="text-biscay font-bold text-4xl md:text-5xl leading-tight tracking-wide mb-8">
        模擬試験を好きなだけ。<br />留学を引き寄せる、<br />モノにする。
      </h1>
      <a href="#" class="btn-primary text-base px-10 py-4">無料実力診断へ</a>
    </div>
    <!-- Hero Image -->
    <div class="md:w-1/2 flex justify-center">
      <%= image_tag "rectangle-77.png", alt: "Hero", class: "w-full max-w-lg rounded-2xl object-cover" %>
    </div>
  </div>
  <!-- Decorative ellipses -->
  <div class="absolute top-14 right-48 w-52 h-44 bg-catskill rounded-full opacity-50"></div>
  <div class="absolute bottom-16 right-10 w-32 h-32 bg-catskill rounded-full opacity-30"></div>
</section>

<!-- ========== PLANS / PRICING ========== -->
<section class="section-bg py-16">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid md:grid-cols-3 gap-6">

      <!-- Plan 1: Section -->
      <div class="exam-card flex flex-col justify-between">
        <div>
          <h3 class="text-biscay font-bold text-2xl mb-4">セクション解き放題プラン</h3>
          <p class="text-sm text-gray-600 mb-6">L / S / R セクション別に集中演習できる定額プランです。</p>
          <div class="space-y-2 mb-4">
            <div class="text-eastern-blue font-bold">苦手分野を明確にしたい</div>
            <div class="text-eastern-blue font-bold">弱点を集中的に対策したい</div>
            <div class="text-eastern-blue font-bold">解答スピードを上げたい</div>
            <div class="text-eastern-blue font-bold">隙間時間で対策したい</div>
          </div>
          <div class="border-t border-eastern-blue/30 pt-4 mt-4">
            <p class="font-bold text-sm text-dark-text">こんな人におススメ</p>
          </div>
        </div>
        <a href="#" class="btn-primary mt-8 text-center text-base py-4">セクション演習へ進む</a>
      </div>

      <!-- Plan 2: Mock Exam -->
      <div class="exam-card flex flex-col justify-between">
        <div>
          <h3 class="text-biscay font-bold text-2xl mb-4">模擬試験</h3>
          <p class="text-sm text-gray-600 mb-6">本番形式の模擬試験で実践力を測定できます。</p>
          <div class="space-y-2 mb-4">
            <div class="text-eastern-blue font-bold">今のスコアを知りたい</div>
            <div class="text-eastern-blue font-bold">試験前に腕試しをしたい</div>
          </div>
          <div class="border-t border-eastern-blue/30 pt-4 mt-4">
            <p class="font-bold text-sm text-dark-text">こんな人におススメ</p>
          </div>
        </div>
        <a href="#" class="btn-primary mt-8 text-center text-base py-4">模擬試験へ進む</a>
      </div>

      <!-- Plan 3: Analysis -->
      <div class="exam-card flex flex-col justify-between">
        <div>
          <h3 class="text-biscay font-bold text-2xl mb-4">分析レポート</h3>
          <p class="text-sm text-gray-600 mb-6">AIが解答データを分析し、セクション別・設問タイプ別に弱点を可視化します。</p>
          <div class="mt-4 bg-white/60 rounded-xl p-4 text-sm text-gray-600">
            <p>解答時間やスコア推移も記録。感覚ではなく、データに基づいた戦略的な学習が可能になります。</p>
          </div>
        </div>
        <a href="#" class="link-arrow mt-8 text-base font-bold">分析レポートについてみる</a>
      </div>

    </div>
  </div>
</section>

<!-- ========== 3 MERITS ========== -->
<section class="section-bg py-20 border-t border-eastern-blue/20">
  <div class="max-w-7xl mx-auto px-6">
    <h2 class="text-center text-3xl font-bold text-dark-text mb-16">Prenessを使う3つのメリット</h2>

    <div class="space-y-20">

      <!-- Merit 01 -->
      <div class="flex flex-col md:flex-row items-start gap-8">
        <div class="merit-number flex-shrink-0">01</div>
        <div class="flex-1">
          <h3 class="text-2xl font-bold text-dark-text mb-4">問題がなくならない。だから、好きなだけ解ける。</h3>
          <p class="text-base text-gray-700 leading-relaxed mb-6">
            常に新しい模擬試験・セクション別問題を提供するため、同じ問題を繰り返し解く必要はありません。Listening・Structure・Readingの全形式に対応し、本番を想定した演習量を確保できます。<br /><br />
            市販教材の問題数に制限されることなく、目標スコアに到達するまで継続的にトレーニングが可能です。
          </p>
          <div class="flex items-center gap-4">
            <%= image_tag "rectangle-58@2x.png", alt: "", class: "h-40 object-contain" %>
            <%= image_tag "arrow-2.svg", alt: "", class: "h-7" %>
            <%= image_tag "rectangle-59@2x.png", alt: "", class: "h-12 object-contain" %>
          </div>
        </div>
      </div>

      <!-- Merit 02 -->
      <div class="flex flex-col md:flex-row items-start gap-8">
        <div class="merit-number flex-shrink-0">02</div>
        <div class="flex-1">
          <h3 class="text-2xl font-bold text-dark-text mb-4">何を伸ばせばいいか、一目でわかる。</h3>
          <p class="text-base text-gray-700 leading-relaxed">
            AIが解答データを分析し、セクション別・設問タイプ別に弱点を可視化します。<br />
            「文法理解が不足しているのか」「時間配分に課題があるのか」まで具体的に把握できます。<br />
            さらに、解答時間やスコア推移も記録されるため、改善の成果を数値で確認できます。<br />
            感覚ではなく、データに基づいた戦略的な学習が可能になります。
          </p>
          <a href="#" class="link-arrow mt-4 inline-flex text-sm">分析レポートについて詳しくみる</a>
        </div>
      </div>

      <!-- Merit 03 -->
      <div class="flex flex-col md:flex-row items-start gap-8">
        <div class="merit-number flex-shrink-0">03</div>
        <div class="flex-1">
          <h3 class="text-2xl font-bold text-dark-text mb-4">スコアの先に、つながりがある。</h3>
          <p class="text-base text-gray-700 leading-relaxed">
            アカウント登録済みの方には、Prenessコミュニティへの参加機会をご案内しています。<br />
            留学志向の高い学習者同士が交流できる環境を提供します。<br />
            単なる試験対策にとどまらず、留学準備やキャリア形成に向けた情報共有や機会創出を行います。<br />
            スコア獲得を"ゴール"ではなく、"次のステージへの通過点"にします。
          </p>
          <a href="#" class="link-arrow mt-4 inline-flex text-sm">コミュニティについて詳しくみる</a>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- ========== CTA BANNER ========== -->
<section class="bg-white py-16 text-center border-y border-eastern-blue/20">
  <div class="max-w-2xl mx-auto px-6">
    <p class="text-lg font-bold text-biscay mb-2">その先の留学へ。</p>
    <h2 class="text-2xl font-bold text-dark-text mb-8">Prenessで‟安心できる学習環境"を整えてみませんか？</h2>
    <a href="#" class="btn-primary text-base px-12 py-4">登録はこちら</a>
  </div>
</section>

<!-- ========== HOW TO USE ========== -->
<section class="section-bg py-20">
  <div class="max-w-5xl mx-auto px-6">
    <h2 class="text-3xl font-bold text-center text-dark-text mb-14">ご利用の流れ</h2>

    <div class="grid md:grid-cols-4 gap-6 text-center">

      <div class="flex flex-col items-center gap-3">
        <div class="w-14 h-14 rounded-full bg-biscay text-white font-bold text-2xl flex items-center justify-center">①</div>
        <h4 class="font-bold text-xl text-biscay">アカウント登録</h4>
        <p class="text-sm text-gray-600">メールアドレスで簡単登録。すぐに演習を開始できます。</p>
      </div>

      <div class="flex flex-col items-center gap-3">
        <div class="w-14 h-14 rounded-full bg-biscay text-white font-bold text-2xl flex items-center justify-center">②</div>
        <h4 class="font-bold text-xl text-biscay">資格を選択</h4>
        <p class="text-sm text-gray-600">目的に応じて試験を選択。<br />TOEFL ITP / TOEFL iBT / IELTS<br /><span class="text-xs text-gray-400">※複数ご登録いただけます。</span></p>
      </div>

      <div class="flex flex-col items-center gap-3">
        <div class="w-14 h-14 rounded-full bg-biscay text-white font-bold text-2xl flex items-center justify-center">③</div>
        <h4 class="font-bold text-xl text-biscay">演習</h4>
        <p class="text-sm text-gray-600">模擬試験とセクション別演習の反復。L / S / Rに対応。</p>
      </div>

      <div class="flex flex-col items-center gap-3">
        <div class="w-14 h-14 rounded-full bg-biscay text-white font-bold text-2xl flex items-center justify-center">④</div>
        <h4 class="font-bold text-xl text-biscay">スコア取得</h4>
        <p class="text-sm text-gray-600">反復演習とデータに基づくレポートにより、スコア向上を目指します。</p>
      </div>

    </div>

    <%= image_tag "rectangle-76.png", alt: "ご利用の流れ", class: "w-full max-w-5xl mx-auto block mt-12 rounded-xl" %>

    <div class="mt-10 text-center">
      <a href="#" class="btn-primary px-10 py-4 text-base">無料実力診断へ</a>
    </div>
  </div>
</section>

<!-- ========== EXAM TYPES ========== -->
