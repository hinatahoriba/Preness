<% content_for :head do %>
<style>

        /* =========================================
           1. CSS Variables (Theme Settings)
        ========================================= */
        :root {
            /* Brand Colors */
            --color-teal: #279ea6;
            --color-teal-dark: #1b99a6;
            --color-teal-light: #75c4c9;
            --color-teal-accent: #38b1ba;
            
            --color-navy: #1f3b60;
            --color-navy-dark: #1a2b4c;
            --color-navy-hero: #2b5f93;
            --color-navy-diagnosis: #256496;
            
            --color-orange: #d87b3e;
            --color-orange-bright: #ef7b2c;
            --color-orange-diagnosis: #ea762a;
            --color-yellow: #d8ce2b;
            
            /* Backgrounds */
            --bg-main: #eef3f7;
            --bg-alt: #f0f4f8;
            --bg-white: #ffffff;
            
            /* Text Colors */
            --text-main: #333333;
            --text-dark: #000000;
            --text-light: #ffffff;
            
            /* Typography */
            --font-primary: 'Yu Gothic', YuGothic, 'Helvetica Neue', Arial, sans-serif;
            --font-serif: Georgia, serif;
        }

        /* =========================================
           2. Base Styles & Resets
        ========================================= */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background-color: var(--bg-main);
            color: var(--text-main);
            font-family: var(--font-primary);
            line-height: 1.6;
            overflow-x: hidden;     /* <-- ADD THIS: Prevents horizontal scrolling */
        }

        a {
            text-decoration: none;
            color: inherit;
        }

        ul {
            list-style: none;
        }

        img {
            max-width: 100%;
            height: auto;
            display: block;
        }

        /* =========================================
           3. Global Utility Components
        ========================================= */
        
        /* Layout */
        .section {
            padding: 20px 0;
        }

        .section--bg-alt {
            background-color: var(--bg-alt);
        }

        .section--bg-navy {
            background-color: var(--color-navy);
            color: var(--text-light);
        }

        .container {
            max-width: 1100px;
            margin: 0 auto;
            padding: 0 20px;
        }

        .container--sm {
            max-width: 900px;
        }

        /* Typography */
        .section-title {
            text-align: center;
            font-size: 28px;
            font-weight: bold;
            color: var(--color-navy);
            margin-bottom: 30px;
            letter-spacing: 1.5px;
        }

        .section-title--light {
            color: var(--text-light);
        }

        /* Button System */
        .btn {
            display: inline-block;
            padding: 12px 35px;
            font-size: 15px;
            font-weight: bold;
            text-align: center;
            cursor: pointer;
            transition: all 0.3s ease;
            border: 2px solid transparent;
            border-radius: 40px; /* Default Pill */
        }

        .btn--radius-sm {
            border-radius: 6px;
        }

        .btn--primary {
            background-color: var(--color-teal);
            color: var(--text-light);
        }
        .btn--primary:hover {
            opacity: 0.9;
        }

        .btn--outline {
            background-color: transparent;
            border-color: var(--color-teal);
            color: var(--color-teal);
        }
        .btn--outline:hover {
            background-color: var(--color-teal);
            color: var(--text-light);
        }

        .btn--accent {
            background-color: #f2f5f9;
            color: var(--color-teal);
            border: 4px solid var(--color-teal-accent);
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        }
        .btn--accent:hover {
            background-color: var(--bg-white);
            transform: translateY(-2px);
            box-shadow: 0 6px 12px rgba(0, 0, 0, 0.15);
        }

        .btn--block {
            display: block;
            width: 100%;
            margin-bottom: 15px;
        }
        .btn--block:last-child {
            margin-bottom: 0;
        }

        /* =========================================
           4. Section-Specific Styles
        ========================================= */

        /* --- Header & Hero --- */
/* Find this block and modify the padding-bottom */
.top-section-wrapper {
    background: linear-gradient(135deg, #0e448b 0%, #4684b5 100%);
    color: var(--text-light);
    overflow: visible;
    padding-bottom: 120px; 
}

        .new-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 25px 0;
        }

        .new-logo {
            display: flex;
            align-items: center;
        }

        .logo-img {
            height: 40px;
            width: auto;
        }

        .new-header-actions {
            display: flex;
            gap: 15px;
        }

        .new-hero {
            display: flex;
            align-items: stretch;
            justify-content: space-between;
            margin-top: 40px;
            gap: 40px;
            margin-bottom: 40px;
        }

        .new-hero-text {
            flex: 1;
        }

        .new-hero-sub {
            font-size: 30px;
            margin-bottom: 30px;
            font-weight: bold;
            letter-spacing: 2px;
            white-space: nowrap;
        }

        .new-hero-main {
            font-size: 38px;
            line-height: 1.6;
            font-weight: bold;
            letter-spacing: 2.5px;
        }

        .new-hero-visual {
            flex: 1;
            position: relative;
            /* display: flex;
            justify-content: flex-end;
            align-items: flex-end; */
            /* min-height: 350px; */
        }

        /* Find this block and modify it */
.img-laptop {
    position: absolute;     /* <-- ADDED: Allows it to ignore container boundaries */
    top: 0;                 /* <-- ADDED: Aligns to the top of the text */
    left: 0;                /* <-- ADDED: Starts exactly where the visual column begins */
    height: 200%;           /* <-- CHANGED: Forces the image to be exactly as tall as the text */
    width: auto;            /* <-- CHANGED: Maintains the image's original aspect ratio */
    max-width: none;        /* <-- CHANGED: Removes the 650px limit so it can bleed off-screen */
    z-index: 1;
    top: 80%;
    transform: translate(15%, -50%);
}

        .img-mobile {
            position: absolute;
            left: -20px;
            bottom: -30px;
            width: 28%;
            max-width: 180px;
            z-index: 2;
            border-radius: 12px;
            box-shadow: 0 15px 30px rgba(0, 0, 0, 0.4);
        }

        /* --- Global Grid Layouts --- */
        .grid-cards {
            display: flex;
            justify-content: center;
            gap: 30px;
            flex-wrap: wrap;
        }

        /* --- Exam Target Cards --- */
        .exam-card {
            background-color: transparent;
            border: 2px solid var(--color-teal);
            border-radius: 20px;
            width: 320px;
            padding: 60px 30px;
            display: flex;
            flex-direction: column;
            align-items: center;
            min-height: 300px;
        }

        .exam-card h2 {
            font-size: 26px;
            margin-bottom: auto;
            color: var(--text-dark);
            letter-spacing: 1px;
        }

        .exam-card-actions {
            width: 100%;
            margin-top: auto;
        }

        /* --- Merits Section --- */
        .merit-item {
            max-width: 800px;
            margin: 0 auto 50px auto;
            text-align: center;
        }

        .merit-item:last-child {
            margin-bottom: 0;
        }

        .merit-header {
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            margin-bottom: 30px;
        }

        .merit-number {
            font-size: 64px;
            font-weight: bold;
            color: var(--color-yellow);
            position: absolute;
            left: 20px;
        }

        .merit-heading {
            font-size: 22px;
            font-weight: bold;
            color: var(--text-dark);
        }

        .merit-text {
            font-size: 14px;
            margin-bottom: 40px;
        }

        .merit-illustration {
            width: 450px;
            margin: 0 auto;
        }

        /* --- Diagnosis Section --- */
        .diagnosis-card {
            background-color: var(--bg-white);
            border-radius: 10px;
            overflow: hidden;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
        }

        .diagnosis-header {
            background-color: var(--bg-alt);
            color: #2b4566;
            text-align: center;
            padding: 22px;
            font-size: 20px;
            font-weight: bold;
            letter-spacing: 2px;
            border-bottom: 2px solid var(--color-navy-diagnosis);
        }

        .diagnosis-body {
            background-color: var(--color-navy-diagnosis);
            padding: 30px 30px;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .diagnosis-flow {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 40px;
            margin-bottom: 50px;
            width: 100%;
        }

        .diagnosis-step {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 20px;
        }

        .step-ring {
            width: 160px;
            height: 160px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            background-color: var(--bg-white);
        }

        .ring-step-1 { background: conic-gradient(var(--color-orange-diagnosis) 0deg 120deg, transparent 120deg 360deg); }
        .ring-step-2 { background: conic-gradient(var(--color-orange-diagnosis) 0deg 240deg, transparent 240deg 360deg); }
        .ring-step-3 { background-color: var(--color-orange-diagnosis); }

        .step-inner {
            width: 146px;
            height: 146px;
            background-color: #f2f5f9;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .step-icon {
            width: 45px;
            height: 45px;
            color: #1a1a1a;
        }

        .step-label {
            color: var(--text-light);
            font-weight: bold;
            letter-spacing: 1px;
        }

        .step-arrow {
            color: var(--color-orange-diagnosis);
            margin-top: -40px;
        }

        .step-arrow svg {
            width: 28px;
            height: 40px;
        }

        /* --- Recommendation Cards --- */
        .rec-card {
            flex: 1;
            min-width: 300px;
            background-color: var(--bg-white);
            border: 1px solid var(--color-teal-light);
            border-radius: 8px;
            padding: 30px 10px;
            text-align: center;
        }

        .rec-title {
            font-size: 20px;
            margin-bottom: 30px;
        }

        .rec-subtitle {
            font-size: 15px;
            margin-bottom: 10px;
        }

        .rec-divider {
            border: none;
            border-top: 1px solid var(--text-dark);
            width: 75%;
            margin: 0 auto 30px auto;
        }

        .rec-list li {
            color: var(--color-teal-dark);
            font-weight: bold;
            margin-bottom: 20px;
        }

        /* --- New Flow Section (ご利用の流れ) --- */
        .flow-container-new {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 50px;
            max-width: 1000px;
            margin: 0 auto;
            padding: 20px 0;
        }

        .flow-panel {
            background-color: #ede2d7; /* Light beige matching the image */
            border-radius: 28px;
            width: 360px;
            min-height: 320px;
            padding: 30px 30px;
            display: flex;
            flex-direction: column;
            align-items: center;
            box-shadow: 0 4px 15px rgba(0,0,0,0.06);
        }

        .flow-panel-title {
            color: var(--color-navy);
            font-size: 18px;
            font-weight: bold;
            margin-bottom: 20px;
            letter-spacing: 1px;
        }

        .flow-options {
            display: flex;
            flex-direction: column;
            gap: 15px;
            width: 100%;
            margin-bottom: 10px;
        }

        .flow-pill {
            padding: 14px 20px;
            border-radius: 30px;
            text-align: center;
            font-weight: bold;
            font-size: 14px;
            border: 1px solid transparent;
        }

        .flow-pill--active {
            background-color: var(--color-teal);
            color: var(--text-light);
        }

        .flow-pill--inactive {
            background-color: #f6f7f8;
            color: #9a9a9a;
            border-color: #e2e2e2;
        }

        .flow-note {
            font-size: 11px;
            color: var(--color-navy);
            font-weight: bold;
            text-align: center;
        }

        .flow-arrow {
            width: 0;
            height: 0;
            border-top: 70px solid transparent;
            border-bottom: 70px solid transparent;
            border-left: 35px solid var(--color-teal);
        }

        /* --- VOICE Section --- */
        .voice-section {
            background: linear-gradient(135deg, #0e448b 0%, #4684b5 100%);
            color: var(--text-light);
        }

        .voice-header {
            display: flex;
            align-items: center;
            margin-bottom: 40px;
        }

        .voice-header-line {
            height: 1px;
            background-color: var(--bg-white);
            width: 15%;
            margin-right: 30px;
        }

        .voice-item {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 80px;
            margin-bottom: 30px;
        }

        .voice-item-reverse {
            flex-direction: row-reverse;
        }

        .voice-profile {
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
            width: 220px;
            flex-shrink: 0;
        }

        .voice-avatar {
            width: 220px;
            height: 220px;
            background-color: #e0e0e0;
            border-radius: 50%;
            display: flex;
            justify-content: center;
            align-items: center;
            color: var(--text-main);
            font-size: 18px;
            font-weight: bold;
            margin-bottom: 25px;
        }

        .voice-name, .voice-role {
            font-size: 18px;
            letter-spacing: 2px;
        }

        .voice-content {
            flex: 1;
            display: flex;
            flex-direction: column;
            gap: 35px;
            margin-top: 50px;
        }

        .voice-line {
            width: 100%;
            border-bottom: 1px solid rgba(255, 255, 255, 0.7);
            padding-bottom: 5px;
        }

        /* --- FAQ Accordion --- */
        .faq-item {
            margin-bottom: 20px; 
            background-color: var(--bg-white);
            border: 1.5px solid var(--color-navy);
            border-radius: 50px;
            overflow: hidden; 
        }

        .faq-question {
            color: var(--color-navy);
            font-weight: bold;
            text-align: center;
            padding: 20px 60px;
            margin: 0;
            cursor: pointer;
            list-style: none;
            position: relative;
        }

        .faq-question::-webkit-details-marker { display: none; }

        .faq-question::after {
            content: '+';
            position: absolute;
            right: 30px;
            top: 50%;
            transform: translateY(-50%);
            font-size: 28px;
        }

        .faq-item[open] .faq-question::after { content: '−'; }
        .faq-item[open] .faq-question { border-bottom: 1px dashed #ccc; }

        .faq-answer {
            padding: 25px 40px 30px;
            background-color: var(--bg-white); 
        }

        /* --- Support Section --- */
        .support-content {
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            gap: 60px;
            margin-bottom: 10px;
        }

        .support-image {
            width: 280px;
            transform: translateX(-20%);
        }
        .support-text-container { flex: 0 0 50%; }
        
        /* Add a relative position to the section so the absolute image positions correctly against the screen edge */
        .support-section-wrapper {
            position: relative;
            overflow: hidden; /* Prevents horizontal scrolling if the image bleeds off */
        }

        /* Style for the new image */
        .support-deco-img {
            position: absolute;
            right: 20px; /* Aligns to the right-most side of the screen */
            top: 50px; /* Adjust this value to vertically align it perfectly */
            width: 150px; /* Adjust to match the actual image size */
            z-index: 0; 
            transform: translateY(-20px);
        }

        /* Ensure the main content stays above the decorative image if they overlap */
        .support-content {
            position: relative;
            z-index: 1; 
        }

        .support-disclaimer {
            font-size: 11px;
            color: #dbe4eb;
            text-align: center;
            padding-top: 40px;
            line-height: 1.8;
        }

        .btn--gray {
            background-color: #9e9e9e;
            color: var(--text-light);
            border: none;
            box-shadow: none;
        }
        .btn--gray:hover {
            background-color: #888888;
        }

        /* --- Footer --- */
        .footer-divider {
            height: 1px;
            background-color: #ffffff;
            margin-bottom: 20px;
        }

        .footer-bottom {
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 12px;
            color: #dbe4eb;
        }
        
        .footer-legal { 
            display: flex; 
            gap: 25px; 
        }

        .footer-legal a {
            color: #dbe4eb;
            transition: color 0.3s ease;
        }
        .footer-legal a:hover { 
            color: var(--text-light); 
        }

        /* =========================================
           5. Responsive Breakpoints
        ========================================= */
        @media (max-width: 1000px) {
            .new-hero {
                flex-direction: column;
                text-align: center;
            }
            .new-hero-visual {
                justify-content: center;
                margin-top: 60px;
            }
            .img-laptop { transform: translateX(0); }
            .img-mobile { left: 10%; }
            
            .diagnosis-flow { gap: 20px; }
            .step-ring { width: 120px; height: 120px; }
            .step-inner { width: 110px; height: 110px; }
            
            .flow-container-new { gap: 30px; }
            
            .support-deco-text { display: none; }

            .support-deco-img { 
                display: none;    /* <-- Hides the image completely on smaller screens */
            }
        }

        @media (max-width: 768px) {
            .section { padding: 50px 0; }
            .section-title { font-size: 24px; margin-bottom: 30px; }
            
            .voice-item, .voice-item-reverse {
                flex-direction: column;
                align-items: center;
                gap: 50px;
            }
            .voice-content { margin-top: 20px; }
            
            .faq-item { border-radius: 30px; }
            .faq-question { padding: 15px 45px 15px 15px; text-align: left; }
            .faq-question::after { right: 15px; font-size: 24px; }
            .faq-answer { padding: 20px; }
            
            .support-content, .footer-bottom {
                flex-direction: column;
                text-align: center;
                gap: 30px;
            }
            .support-text-container { flex: 1; }
            .footer-legal { flex-wrap: wrap; justify-content: center; }
            
            .flow-container-new {
                flex-direction: column;
            }
            .flow-arrow {
                transform: rotate(90deg);
            }
            .flow-panel {
                width: 100%;
                max-width: 360px;
            }
        }

        @media (max-width: 600px) {
            .new-header { flex-direction: column; gap: 20px; }
            .new-hero-main { font-size: 28px; }
            
            .diagnosis-body { padding: 40px 20px; }
            .diagnosis-flow { flex-direction: column; gap: 30px; }
            .step-arrow { transform: rotate(90deg); margin-top: 0; }
            .btn--accent { width: 100%; }
        }
    
</style>
<% end %>


    <div class="top-section-wrapper">
        <div class="container">
            <header class="new-header">
                <a href="#" class="new-logo">
                    <%= image_tag "preness_logo.svg", alt: "Preness", class: "logo-img" %>
                </a>
                <div class="new-header-actions">
                    <%= link_to "アカウント登録", new_user_registration_path, class: "btn btn--primary" %>
                    <%= link_to "ログイン", new_user_session_path, class: "btn btn--primary" %>
                </div>
            </header>

            <section class="new-hero">
                <div class="new-hero-text">
                    <p class="new-hero-sub">精密分析 × 圧倒的な演習量でスコアを伸ばす</p>
                    <h1 class="new-hero-main">“なんとなくの勉強”から、<br>“結果につながる学習”へ。</h1>
                </div>
                
                <div class="new-hero-visual">
                    <%= image_tag "laptop.svg", alt: "Preness Dashboard on Laptop", class: "img-laptop" %>
                </div>
            </section>
        </div>
    </div>

    <main>
        <section class="section">
            <div class="container grid-cards">
                <div class="exam-card">
                    <h2>TOEFL ITP</h2>
                    <div class="exam-card-actions">
                        <%= link_to "アカウント登録", new_user_registration_path, class: "btn btn--primary btn--block" %>
                        <%= link_to "ログイン", new_user_session_path, class: "btn btn--primary btn--block" %>
                    </div>
                </div>

                <div class="exam-card">
                    <h2>TOEFL iBT</h2>
                    <div class="exam-card-actions">
                        <a href="#" class="btn btn--outline btn--block">Coming Soon...</a>
                    </div>
                </div>

                <div class="exam-card">
                    <h2>IELTS</h2>
                    <div class="exam-card-actions">
                        <a href="#" class="btn btn--outline btn--block">Coming Soon...</a>
                    </div>
                </div>
            </div>
        </section>

        <section class="section section--bg-alt">
            <div class="container container--sm">
                <div class="diagnosis-card">
                    <div class="diagnosis-header">
                        無料弱点診断 実施中！
                    </div>
                    <div class="diagnosis-body">
                        <div class="diagnosis-flow">
                            <div class="diagnosis-step">
                                <div class="step-ring ring-step-1">
                                    <div class="step-inner">
                                        <svg class="step-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"></path>
                                            <path d="m15 5 4 4"></path>
                                        </svg>
                                    </div>
                                </div>
                                <div class="step-label">弱点診断</div>
                            </div>
                            <div class="step-arrow">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                                    <polyline points="9 18 15 12 9 6"></polyline>
                                </svg>
                            </div>
                            <div class="diagnosis-step">
                                <div class="step-ring ring-step-2">
                                    <div class="step-inner">
                                        <svg class="step-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <circle cx="11" cy="11" r="8"></circle>
                                            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                                        </svg>
                                    </div>
                                </div>
                                <div class="step-label">弱点分析</div>
                            </div>
                            <div class="step-arrow">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                                    <polyline points="9 18 15 12 9 6"></polyline>
                                </svg>
                            </div>
                            <div class="diagnosis-step">
