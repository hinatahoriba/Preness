  <div class="max-w-5xl mx-auto px-6">
    <h2 class="text-3xl font-bold text-center text-dark-text mb-12">ご利用料金</h2>

    <div class="grid md:grid-cols-3 gap-6 text-center">

      <div class="border border-eastern-blue/40 rounded-2xl p-8 hover:shadow-lg transition">
