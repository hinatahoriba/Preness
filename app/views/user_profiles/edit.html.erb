<main class="flex-grow max-w-4xl w-full mx-auto px-4 md:px-6 py-8 md:py-12 animate-fadeInUp">
  <div class="max-w-lg mx-auto">
    <div class="mb-6">
      <%= link_to account_setting_path, class: "inline-flex items-center space-x-1 text-xs text-gray-400 hover:text-brand-navy font-bold mb-4 transition" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
        <span>アカウント設定に戻る</span>
      <% end %>
      <h2 class="text-2xl md:text-3xl font-black text-brand-navy mb-2 tracking-tight">プロフィール編集</h2>
      <p class="text-xs text-gray-400">基本情報を編集できます。</p>
    </div>

    <div class="bg-white border border-brand-teal/10 rounded-[32px] shadow-sm p-6 md:p-8">
      <%= form_with model: @user_profile, url: user_profile_path, method: :patch, class: "space-y-6" do |f| %>
        <% if @user_profile.errors.any? %>
          <div class="rounded-2xl border border-red-300 bg-red-50 px-4 py-3 text-xs font-bold text-red-700">
            <ul class="list-disc list-inside space-y-1">
              <% @user_profile.errors.full_messages.each do |msg| %>
                <li><%= msg %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <%# 基本情報 %>
        <div>
          <h3 class="text-[11px] font-black text-brand-teal border-b border-gray-100 pb-2.5 mb-5 tracking-wider">基本情報</h3>
          <div class="space-y-4">
            <div>
              <label class="block text-xs font-bold text-brand-navy mb-2">氏名</label>
              <div class="flex space-x-3">
                <%= f.text_field :last_name, placeholder: "姓", autocomplete: "family-name",
                  class: "w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-brand-teal/30 focus:border-brand-teal placeholder-gray-400 transition" %>
                <%= f.text_field :first_name, placeholder: "名", autocomplete: "given-name",
                  class: "w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-brand-teal/30 focus:border-brand-teal placeholder-gray-400 transition" %>
              </div>
            </div>
            <div>
              <label class="block text-xs font-bold text-brand-navy mb-2">フリガナ</label>
              <div class="flex space-x-3">
                <%= f.text_field :last_name_kana, placeholder: "セイ",
                  class: "w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-brand-teal/30 focus:border-brand-teal placeholder-gray-400 transition" %>
                <%= f.text_field :first_name_kana, placeholder: "メイ",
                  class: "w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-brand-teal/30 focus:border-brand-teal placeholder-gray-400 transition" %>
              </div>
            </div>
            <div>
              <%= f.label :nickname, "ニックネーム", class: "block text-xs font-bold text-brand-navy mb-2" %>
              <%= f.text_field :nickname, placeholder: "たろう", class: "w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-brand-teal/30 focus:border-brand-teal placeholder-gray-400 transition" %>
            </div>
            <div>
              <%= f.label :date_of_birth, "生年月日", class: "block text-xs font-bold text-brand-navy mb-2" %>
              <%= f.date_field :date_of_birth, autocomplete: "bday",
                class: "w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-brand-teal/30 focus:border-brand-teal text-brand-navy bg-white transition" %>
            </div>
          </div>
        </div>

        <%# 所属と学習目的 %>
        <div>
          <h3 class="text-[11px] font-black text-brand-teal border-b border-gray-100 pb-2.5 mb-5 tracking-wider">所属と学習目的</h3>
          <div class="space-y-4">
            <div>
              <%= f.label :affiliation, "大学・組織名", class: "block text-xs font-bold text-brand-navy mb-2" %>
              <%= f.text_field :affiliation, placeholder: "○○大学、○○高校、語学学校、その他", class: "w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-brand-teal/30 focus:border-brand-teal placeholder-gray-400 transition" %>
            </div>

            <div>
              <%= f.label :study_abroad_plan, "留学予定の有無", class: "block text-xs font-bold text-brand-navy mb-3" %>
              <div class="grid grid-cols-2 gap-4">
                <label class="flex items-center justify-center border border-gray-200 bg-white rounded-xl py-3 cursor-pointer hover:border-brand-teal/50 transition-colors has-[:checked]:border-brand-teal has-[:checked]:ring-1 has-[:checked]:ring-brand-teal">
                  <%= f.radio_button :study_abroad_plan, "true", class: "w-4 h-4 text-brand-teal border-gray-300 focus:ring-brand-teal/30" %>
                  <span class="ml-2 text-xs font-bold text-brand-navy">あり</span>
                </label>
                <label class="flex items-center justify-center border border-gray-200 bg-white rounded-xl py-3 cursor-pointer hover:border-brand-teal/50 transition-colors has-[:checked]:border-brand-teal has-[:checked]:ring-1 has-[:checked]:ring-brand-teal">
                  <%= f.radio_button :study_abroad_plan, "false", class: "w-4 h-4 text-brand-teal border-gray-300 focus:ring-brand-teal/30" %>
                  <span class="ml-2 text-xs font-bold text-brand-navy">なし</span>
                </label>
              </div>
            </div>
          </div>
        </div>

        <%# 資格・スコア %>
        <div>
          <h3 class="text-[11px] font-black text-brand-teal border-b border-gray-100 pb-2.5 mb-5 tracking-wider">資格・スコア</h3>
          <div class="space-y-4">
            <div>
              <%= f.label :eiken_grade, "英検 取得級", class: "block text-xs font-bold text-brand-navy mb-2" %>
              <%= f.select :eiken_grade, options_for_select([["1級", "1"], ["準1級", "p1"], ["2級", "2"], ["準2級", "p2"], ["3級", "3"]], @user_profile.eiken_grade),
                { include_blank: "級を選択" }, class: "w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-brand-teal/30 focus:border-brand-teal bg-white text-brand-navy transition" %>
            </div>
            <div>
              <%= f.label :toeic_score, "TOEIC L&R スコア", class: "block text-xs font-bold text-brand-navy mb-2" %>
              <%= f.number_field :toeic_score, min: 10, max: 990, step: 5, inputmode: "numeric", placeholder: "10 - 990",
                class: "w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-brand-teal/30 focus:border-brand-teal placeholder-gray-400 transition" %>
            </div>
            <div>
              <%= f.label :toefl_ibt_score, "TOEFL iBT スコア", class: "block text-xs font-bold text-brand-navy mb-2" %>
              <%= f.number_field :toefl_ibt_score, min: 0, max: 120, inputmode: "numeric", placeholder: "0 - 120",
                class: "w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-brand-teal/30 focus:border-brand-teal placeholder-gray-400 transition" %>
            </div>
            <div>
              <%= f.label :ielts_score, "IELTS バンドスコア", class: "block text-xs font-bold text-brand-navy mb-2" %>
              <%= f.number_field :ielts_score, min: 0, max: 9.0, step: 0.5, inputmode: "decimal", placeholder: "0.0 - 9.0",
                class: "w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-brand-teal/30 focus:border-brand-teal placeholder-gray-400 transition" %>
            </div>
          </div>
        </div>

        <div class="flex items-center gap-4 pt-4">
          <%= link_to "キャンセル", account_setting_path, class: "flex-1 text-center rounded-2xl border border-gray-200 px-4 py-3.5 text-xs font-black text-gray-400 hover:bg-gray-50 transition" %>
          <%= f.submit "保存する", class: "flex-1 rounded-2xl bg-brand-teal hover:opacity-90 px-4 py-3.5 text-xs font-black text-white transition cursor-pointer shadow-lg shadow-teal-500/10" %>
        </div>
      <% end %>
    </div>
  </div>
</main>
