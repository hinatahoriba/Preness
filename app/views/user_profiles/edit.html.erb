<% content_for :body_class, "bg-[#f9fafb] text-[#374151] h-screen" %>

<div class="flex h-full">
  <%= render 'shared/sidebar', active_page: :account_settings %>

  <%# メインコンテンツ %>
  <main class="flex-1 p-8 overflow-y-auto">
    <div class="max-w-lg mx-auto">
      <div class="mb-6">
        <%= link_to account_setting_path, class: "inline-flex items-center space-x-1 text-sm text-gray-500 hover:text-gray-700 font-medium mb-4 transition" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
          <span>アカウント設定に戻る</span>
        <% end %>
        <h2 class="text-2xl font-bold mb-2">プロフィール編集</h2>
        <p class="text-sm text-gray-500">基本情報を編集できます。</p>
      </div>

      <div class="bg-white border border-gray-200 rounded-lg shadow-sm p-8">
        <%= form_with model: @user_profile, url: user_profile_path, method: :patch, class: "space-y-6" do |f| %>
          <% if @user_profile.errors.any? %>
            <div class="rounded-xl border border-red-300 bg-red-50 px-4 py-3 text-sm text-red-700">
              <ul class="list-disc list-inside space-y-1">
                <% @user_profile.errors.full_messages.each do |msg| %>
                  <li><%= msg %></li>
                <% end %>
              </ul>
            </div>
          <% end %>

          <%# 基本情報 %>
          <div>
            <h3 class="text-xs font-bold text-teal-600 border-b border-gray-100 pb-2 mb-5 tracking-wide">基本情報</h3>
            <div class="space-y-5">
              <div>
                <label class="block text-sm font-bold mb-2">氏名</label>
                <div class="flex space-x-3">
                  <%= f.text_field :last_name, placeholder: "姓", autocomplete: "family-name",
                    class: "w-full border border-gray-300 rounded-xl px-4 py-3.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal-400 focus:border-transparent placeholder-gray-400 transition-shadow" %>
                  <%= f.text_field :first_name, placeholder: "名", autocomplete: "given-name",
                    class: "w-full border border-gray-300 rounded-xl px-4 py-3.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal-400 focus:border-transparent placeholder-gray-400 transition-shadow" %>
                </div>
              </div>
              <div>
                <label class="block text-sm font-bold mb-2">フリガナ</label>
                <div class="flex space-x-3">
                  <%= f.text_field :last_name_kana, placeholder: "セイ",
                    class: "w-full border border-gray-300 rounded-xl px-4 py-3.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal-400 focus:border-transparent placeholder-gray-400 transition-shadow" %>
                  <%= f.text_field :first_name_kana, placeholder: "メイ",
                    class: "w-full border border-gray-300 rounded-xl px-4 py-3.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal-400 focus:border-transparent placeholder-gray-400 transition-shadow" %>
                </div>
              </div>
              <div>
                <%= f.label :nickname, "ニックネーム", class: "block text-sm font-bold mb-2" %>
                <%= f.text_field :nickname, placeholder: "たろう", class: "w-full border border-gray-300 rounded-xl px-4 py-3.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal-400 focus:border-transparent placeholder-gray-400 transition-shadow" %>
              </div>
              <div>
                <%= f.label :date_of_birth, "生年月日", class: "block text-sm font-bold mb-2" %>
                <%= f.date_field :date_of_birth, autocomplete: "bday",
                  class: "w-full border border-gray-300 rounded-xl px-4 py-3.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal-400 focus:border-transparent text-gray-700 bg-white transition-shadow" %>
              </div>
            </div>
          </div>

          <%# 所属と学習目的 %>
          <div>
            <h3 class="text-xs font-bold text-teal-600 border-b border-gray-100 pb-2 mb-5 tracking-wide">所属と学習目的</h3>
            <div class="space-y-5">
              <div>
                <%= f.label :affiliation, "大学・組織名", class: "block text-sm font-bold mb-2" %>
                <%= f.text_field :affiliation, placeholder: "○○大学、○○高校、語学学校、その他", class: "w-full border border-gray-300 rounded-xl px-4 py-3.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal-400 focus:border-transparent placeholder-gray-400 transition-shadow" %>
              </div>

              <div>
                <%= f.label :study_abroad_plan, "留学予定の有無", class: "block text-sm font-bold mb-3" %>
                <div class="grid grid-cols-2 gap-4">
                  <label class="flex items-center justify-center border border-gray-300 bg-white rounded-xl py-3 cursor-pointer hover:border-teal-400 transition-colors has-[:checked]:border-teal-500 has-[:checked]:ring-1 has-[:checked]:ring-teal-500">
                    <%= f.radio_button :study_abroad_plan, "true", class: "w-4 h-4 text-teal-500 border-gray-300 focus:ring-teal-400" %>
                    <span class="ml-2 text-sm font-bold">あり</span>
                  </label>
                  <label class="flex items-center justify-center border border-gray-300 bg-white rounded-xl py-3 cursor-pointer hover:border-teal-400 transition-colors has-[:checked]:border-teal-500 has-[:checked]:ring-1 has-[:checked]:ring-teal-500">
                    <%= f.radio_button :study_abroad_plan, "false", class: "w-4 h-4 text-teal-500 border-gray-300 focus:ring-teal-400" %>
                    <span class="ml-2 text-sm font-bold">なし</span>
                  </label>
                </div>
              </div>
            </div>
          </div>

          <%# 資格・スコア %>
          <div>
            <h3 class="text-xs font-bold text-teal-600 border-b border-gray-100 pb-2 mb-5 tracking-wide">資格・スコア</h3>
            <div class="space-y-5">
              <div>
                <%= f.label :eiken_grade, "英検 取得級", class: "block text-sm font-bold mb-2" %>
                <%= f.select :eiken_grade, options_for_select([["1級", "1"], ["準1級", "p1"], ["2級", "2"], ["準2級", "p2"], ["3級", "3"]], @user_profile.eiken_grade),
                  { include_blank: "級を選択" }, class: "w-full border border-gray-300 rounded-xl px-4 py-3.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal-400 focus:border-transparent bg-white transition-shadow" %>
              </div>
              <div>
                <%= f.label :toeic_score, "TOEIC L&R スコア", class: "block text-sm font-bold mb-2" %>
                <%= f.number_field :toeic_score, min: 10, max: 990, step: 5, inputmode: "numeric", placeholder: "10 - 990",
                  class: "w-full border border-gray-300 rounded-xl px-4 py-3.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal-400 focus:border-transparent placeholder-gray-400 transition-shadow" %>
              </div>
              <div>
                <%= f.label :toefl_ibt_score, "TOEFL iBT スコア", class: "block text-sm font-bold mb-2" %>
                <%= f.number_field :toefl_ibt_score, min: 0, max: 120, inputmode: "numeric", placeholder: "0 - 120",
                  class: "w-full border border-gray-300 rounded-xl px-4 py-3.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal-400 focus:border-transparent placeholder-gray-400 transition-shadow" %>
              </div>
              <div>
                <%= f.label :ielts_score, "IELTS バンドスコア", class: "block text-sm font-bold mb-2" %>
                <%= f.number_field :ielts_score, min: 0, max: 9.0, step: 0.5, inputmode: "decimal", placeholder: "0.0 - 9.0",
                  class: "w-full border border-gray-300 rounded-xl px-4 py-3.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal-400 focus:border-transparent placeholder-gray-400 transition-shadow" %>
              </div>
            </div>
          </div>

          <div class="flex items-center gap-4 pt-2">
            <%= link_to "キャンセル", account_setting_path, class: "flex-1 text-center rounded-xl border border-gray-300 px-4 py-3 text-sm font-semibold text-gray-600 hover:bg-gray-50 transition" %>
            <%= f.submit "保存する", class: "flex-1 rounded-xl bg-teal-500 hover:bg-teal-600 px-4 py-3 text-sm font-semibold text-white transition cursor-pointer" %>
          </div>
        <% end %>
      </div>
    </div>
  </main>
</div>
