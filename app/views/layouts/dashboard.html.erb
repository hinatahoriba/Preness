<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Preness" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-white text-brand-navy antialiased min-h-screen flex flex-col font-sans pb-24 md:pb-0">
    <% if notice.present? || alert.present? %>
      <div class="fixed inset-x-0 top-4 z-50 mx-auto w-full max-w-2xl px-4 transition-opacity duration-500" data-controller="flash">
        <% if notice.present? %>
          <p class="rounded-lg border border-green-300 bg-green-100 px-4 py-3 text-sm font-medium text-green-800" data-flash-target="message"><%= notice %></p>
        <% end %>
        <% if alert.present? %>
          <p class="mt-2 rounded-lg border border-red-300 bg-red-100 px-4 py-3 text-sm font-medium text-red-800" data-flash-target="message"><%= alert %></p>
        <% end %>
      </div>
    <% end %>

    <%# 共通ヘッダー %>
    <header class="bg-white border-b border-gray-100 px-6 md:px-10 py-4 md:py-5 flex justify-between items-center z-50 relative flex-shrink-0">
      <div class="text-brand-orange text-2xl md:text-[26px] font-black tracking-tighter">
        <%= link_to "Preness", mypage_path, class: "hover:opacity-90" %>
      </div>
      <nav class="hidden md:flex items-center space-x-2 text-[13px] font-bold text-gray-400">
        <%= link_to mypage_path, class: "#{controller_name == 'mypages' ? 'bg-brand-orange-light text-brand-orange' : ''} px-5 py-2 rounded-full transition duration-300 hover:text-gray-700 flex items-center gap-1.5" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
          </svg>
          ホーム
        <% end %>
        <%= link_to histories_path, class: "#{controller_name == 'histories' ? 'bg-brand-orange-light text-brand-orange' : ''} px-5 py-2 rounded-full transition duration-300 hover:text-gray-700 flex items-center gap-1.5" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          受験履歴
        <% end %>
        <a href="https://form.run/embed/@official-BbR9Vk77aUJxxyBMWfyw?embed=direct" target="_blank" rel="noopener noreferrer" class="px-5 py-2 rounded-full transition duration-300 hover:text-gray-700 flex items-center gap-1.5">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
          </svg>
          問い合わせ
        </a>
        <%= link_to account_setting_path, class: "#{controller_name == 'account_settings' || controller_name == 'user_profiles' || (controller_name == 'registrations' && action_name == 'edit') ? 'bg-brand-orange-light text-brand-orange' : ''} px-5 py-2 rounded-full transition duration-300 hover:text-gray-700 flex items-center gap-1.5" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          設定
        <% end %>
      </nav>
    </header>

    <%# メインコンテンツ %>
    <%= yield %>

    <%# スマートフォン向けボトムナビゲーション %>
    <nav class="md:hidden fixed bottom-0 left-0 w-full bg-white shadow-[0_-4px_15px_rgba(0,0,0,0.03)] border-t border-gray-100 px-4 py-2 z-50 rounded-t-[1.5rem] flex justify-between items-center pb-safe">
      <%= link_to mypage_path, class: "flex flex-col items-center justify-center flex-1 py-2 group" do %>
        <div class="<%= controller_name == 'mypages' ? 'bg-brand-orange-light text-brand-orange' : 'text-gray-400' %> p-2.5 rounded-xl mb-1 transition duration-300 group-hover:bg-orange-100">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
          </svg>
        </div>
        <span class="text-[10px] font-bold <%= controller_name == 'mypages' ? 'text-brand-orange' : 'text-gray-400' %>">ホーム</span>
      <% end %>

      <%= link_to histories_path, class: "flex flex-col items-center justify-center flex-1 py-2 group text-gray-400 hover:text-gray-600 transition" do %>
        <div class="<%= controller_name == 'histories' ? 'bg-brand-orange-light text-brand-orange' : 'text-gray-400' %> p-2.5 rounded-xl mb-1 transition-transform duration-300 group-hover:-translate-y-0.5 group-hover:scale-105">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <span class="text-[10px] font-bold <%= controller_name == 'histories' ? 'text-brand-orange' : 'text-gray-400' %>">受験履歴</span>
      <% end %>

      <a href="https://form.run/embed/@official-BbR9Vk77aUJxxyBMWfyw?embed=direct" target="_blank" rel="noopener noreferrer" class="flex flex-col items-center justify-center flex-1 py-2 group text-gray-400 hover:text-gray-600 transition">
        <div class="p-2.5 mb-1 transition-transform duration-300 group-hover:-translate-y-0.5 group-hover:scale-105">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
          </svg>
        </div>
        <span class="text-[10px] font-bold">問い合わせ</span>
      </a>

      <%= link_to account_setting_path, class: "flex flex-col items-center justify-center flex-1 py-2 group text-gray-400 hover:text-gray-600 transition" do %>
        <div class="<%= controller_name == 'account_settings' || controller_name == 'user_profiles' || (controller_name == 'registrations' && action_name == 'edit') ? 'bg-brand-orange-light text-brand-orange' : 'text-gray-400' %> p-2.5 rounded-xl mb-1 transition-transform duration-300 group-hover:-translate-y-0.5 group-hover:scale-105">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
        </div>
        <span class="text-[10px] font-bold <%= controller_name == 'account_settings' || controller_name == 'user_profiles' || (controller_name == 'registrations' && action_name == 'edit') ? 'text-brand-orange' : 'text-gray-400' %>">設定</span>
      <% end %>
    </nav>
  </body>
</html>
