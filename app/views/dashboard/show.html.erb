<% content_for :title, "マイページ | Preness" %>

<div class="card shadow-sm border-0 rounded-4">
  <div class="card-body p-4 p-md-5">
    <p class="text-uppercase text-secondary small fw-semibold mb-2">My Page</p>
    <h1 class="h3 fw-bold mb-3">ようこそ、<%= current_user.email %> さん</h1>
    <p class="text-secondary mb-4">
      ここがPrenessのマイページです。今後、学習履歴やスコア分析をこの画面で確認できるように拡張できます。
    </p>

    <div class="d-flex flex-wrap gap-2">
      <%= link_to "プロフィール編集", edit_user_registration_path, class: "btn btn-outline-dark" %>
      <%= button_to "ログアウト", destroy_user_session_path, method: :delete, class: "btn btn-dark", form: { class: "d-inline" } %>
      <%= link_to "LPへ戻る", root_path, class: "btn btn-link px-0" %>
    </div>
  </div>
</div>
