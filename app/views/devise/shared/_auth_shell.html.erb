<section class="min-h-screen bg-white px-4 py-12 text-slate-900 sm:px-6 sm:py-16">
  <div class="mx-auto w-full max-w-lg">
    <div class="rounded-2xl border border-orange-200 bg-white p-6 sm:p-8">
      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-orange-500">Preness Account</p>
      <h1 class="mt-2 text-2xl font-bold leading-tight text-slate-900 sm:text-3xl"><%= title %></h1>
      <% if subtitle.present? %>
        <p class="mt-3 text-sm leading-relaxed text-slate-600"><%= subtitle %></p>
      <% end %>

      <div class="mt-8">
        <%= yield %>
      </div>
    </div>
  </div>
</section>
