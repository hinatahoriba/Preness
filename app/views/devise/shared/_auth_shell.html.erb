<section class="min-h-screen bg-gray-50 flex flex-col items-center justify-center px-4 py-12 text-slate-900 sm:px-6">
  <div class="mx-auto w-full max-w-md">

    <div class="mb-8 text-center">
      <h1 class="text-2xl font-bold text-slate-800 mb-2"><%= local_assigns[:title] || "Preness" %></h1>
      <% if local_assigns[:subtitle] %>
        <p class="text-sm text-gray-500"><%= subtitle %></p>
      <% end %>
    </div>

    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
      <div class="p-8">
        <%= yield %>
      </div>
    </div>

  </div>
</section>
