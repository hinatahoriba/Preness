<div class="mt-6 flex flex-wrap gap-3 text-sm">
  <%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
    <%= link_to "パスワードを忘れた場合", new_password_path(resource_name), class: "font-medium text-preness-700 hover:text-preness-800" %>
  <% end %>

  <%- if devise_mapping.confirmable? && controller_name != 'confirmations' %>
    <%= link_to "確認メールを再送する", new_confirmation_path(resource_name), class: "font-medium text-preness-700 hover:text-preness-800" %>
  <% end %>
</div>
