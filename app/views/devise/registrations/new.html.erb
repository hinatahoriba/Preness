<%= render "devise/shared/auth_shell", subtitle: "アカウントを作成して学習を始めましょう" do %>
  <%= render "devise/shared/auth_tabs" %>
  <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-6" }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div>
      <%= f.label :username, "ユーザー名", class: "text-sm font-medium text-slate-700" %>
      <%= f.text_field :username, autofocus: true, autocomplete: "nickname", class: "mt-1 w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-slate-900 placeholder-slate-400 outline-none ring-0 transition focus:border-preness-400 focus:ring-2 focus:ring-preness-300/40" %>
    </div>

    <div>
      <%= f.label :email, "メールアドレス", class: "text-sm font-medium text-slate-700" %>
      <%= f.email_field :email, autocomplete: "email", class: "mt-1 w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-slate-900 placeholder-slate-400 outline-none ring-0 transition focus:border-preness-400 focus:ring-2 focus:ring-preness-300/40" %>
    </div>

    <div>
      <div class="flex items-baseline justify-between mb-1">
        <%= f.label :password, "パスワード", class: "text-sm font-medium text-slate-700" %>
        <% if @minimum_password_length %>
          <span class="text-xs text-gray-400">最低<%= @minimum_password_length %>文字</span>
        <% end %>
      </div>
      <%= f.password_field :password, autocomplete: "new-password", class: "mt-1 w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-slate-900 placeholder-slate-400 outline-none ring-0 transition focus:border-preness-400 focus:ring-2 focus:ring-preness-300/40" %>
    </div>

    <div>
      <%= f.label :password_confirmation, "パスワード（確認）", class: "text-sm font-medium text-slate-700" %>
      <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "mt-1 w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-slate-900 placeholder-slate-400 outline-none ring-0 transition focus:border-preness-400 focus:ring-2 focus:ring-preness-300/40" %>
    </div>

    <div class="flex items-start gap-3">
      <%= f.check_box :terms_agreed, required: true, class: "mt-1 h-4 w-4 rounded border-gray-300 text-preness-500 focus:ring-preness-500 cursor-pointer" %>
      <span class="text-sm leading-relaxed text-gray-600">
        <%= link_to "利用規約", terms_path, class: "text-preness-600 hover:underline" %>
        および
        <%= link_to "プライバシーポリシー", privacy_path, class: "text-preness-600 hover:underline" %>
        に同意して登録します
      </span>
    </div>

    <%= f.submit "登録する", class: "inline-flex w-full items-center justify-center rounded-xl bg-preness-500 px-4 py-3 text-sm font-semibold text-white transition hover:bg-preness-600" %>
  <% end %>

  <%= render "devise/shared/links" %>
<% end %>
