<%= render "devise/shared/auth_shell", subtitle: "アカウントを作成して学習を始めましょう" do %>
  <%= render "devise/shared/auth_tabs" %>
  <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-6" }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div>
      <%= f.label :email, "メールアドレス", class: "text-sm font-medium text-slate-700" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "mt-1 w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-slate-900 placeholder-slate-400 outline-none ring-0 transition focus:border-preness-400 focus:ring-2 focus:ring-preness-300/40" %>
    </div>

    <div>
      <div class="flex items-baseline justify-between mb-1">
        <%= f.label :password, "パスワード", class: "text-sm font-medium text-slate-700" %>
        <% if @minimum_password_length %>
          <span class="text-xs text-gray-400">最低<%= @minimum_password_length %>文字</span>
        <% end %>
      </div>
      <div data-controller="password-visibility" class="relative mt-1">
        <%= f.password_field :password, autocomplete: "new-password", class: "w-full rounded-xl border border-slate-300 bg-white px-4 pr-12 py-3 text-slate-900 placeholder-slate-400 outline-none ring-0 transition focus:border-preness-400 focus:ring-2 focus:ring-preness-300/40", data: { password_visibility_target: "input" } %>
        <button type="button" class="absolute inset-y-0 right-3 flex items-center justify-center px-2 text-slate-500 transition hover:text-slate-700 focus:outline-none focus:ring-2 focus:ring-preness-300/40 rounded-md" data-action="password-visibility#toggle" data-password-visibility-target="button" aria-pressed="false">
          <span class="sr-only" data-password-visibility-target="label">表示</span>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true" data-password-visibility-target="showIcon">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true" data-password-visibility-target="hideIcon">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.98 8.223A10.477 10.477 0 001.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.45 10.45 0 0112 4.5c4.756 0 8.773 3.162 10.065 7.498a10.523 10.523 0 01-4.293 5.774M6.228 6.228L3 3m3.228 3.228l3.65 3.65m7.894 7.894L21 21m-3.228-3.228l-3.65-3.65m0 0a3 3 0 10-4.243-4.243m4.243 4.243L9.88 9.88" />
          </svg>
        </button>
      </div>
    </div>

    <div>
      <%= f.label :password_confirmation, "パスワード（確認）", class: "text-sm font-medium text-slate-700" %>
      <div data-controller="password-visibility" class="relative mt-1">
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "w-full rounded-xl border border-slate-300 bg-white px-4 pr-12 py-3 text-slate-900 placeholder-slate-400 outline-none ring-0 transition focus:border-preness-400 focus:ring-2 focus:ring-preness-300/40", data: { password_visibility_target: "input" } %>
        <button type="button" class="absolute inset-y-0 right-3 flex items-center justify-center px-2 text-slate-500 transition hover:text-slate-700 focus:outline-none focus:ring-2 focus:ring-preness-300/40 rounded-md" data-action="password-visibility#toggle" data-password-visibility-target="button" aria-pressed="false">
          <span class="sr-only" data-password-visibility-target="label">表示</span>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true" data-password-visibility-target="showIcon">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true" data-password-visibility-target="hideIcon">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.98 8.223A10.477 10.477 0 001.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.45 10.45 0 0112 4.5c4.756 0 8.773 3.162 10.065 7.498a10.523 10.523 0 01-4.293 5.774M6.228 6.228L3 3m3.228 3.228l3.65 3.65m7.894 7.894L21 21m-3.228-3.228l-3.65-3.65m0 0a3 3 0 10-4.243-4.243m4.243 4.243L9.88 9.88" />
          </svg>
        </button>
      </div>
    </div>

    <div class="flex items-start gap-3">
      <%= f.check_box :terms_agreed, required: true, class: "mt-1 h-4 w-4 rounded border-gray-300 text-preness-500 focus:ring-preness-500 cursor-pointer" %>
      <span class="text-sm leading-relaxed text-gray-600">
        <%= link_to "利用規約", terms_path, class: "text-preness-600 hover:underline" %>
        および
        <%= link_to "プライバシーポリシー", privacy_path, class: "text-preness-600 hover:underline" %>
        に同意して登録します
      </span>
    </div>

    <%= f.submit "登録する", class: "inline-flex w-full items-center justify-center rounded-xl bg-preness-500 px-4 py-3 text-sm font-semibold text-white transition hover:bg-preness-600" %>
  <% end %>

  <%= render "devise/shared/links" %>
<% end %>
