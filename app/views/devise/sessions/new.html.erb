<%= render "devise/shared/auth_shell", subtitle: "登録済みのアカウントでログインします" do %>
  <%= render "devise/shared/auth_tabs" %>
  <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-6" }) do |f| %>
    <div>
      <%= f.label :email, "メールアドレス", class: "block text-sm font-bold mb-2 text-slate-700" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "w-full px-4 py-3 border border-gray-200 rounded-lg outline-none transition focus:border-preness-400 focus:ring-2 focus:ring-preness-300/20 text-slate-900 placeholder-slate-400" %>
    </div>

    <div>
      <%= f.label :password, "パスワード", class: "block text-sm font-bold mb-2 text-slate-700" %>
      <%= f.password_field :password, autocomplete: "current-password", class: "w-full px-4 py-3 border border-gray-200 rounded-lg outline-none transition focus:border-preness-400 focus:ring-2 focus:ring-preness-300/20 text-slate-900 placeholder-slate-400" %>
    </div>

    <% if devise_mapping.rememberable? %>
      <label class="flex items-center gap-3 text-sm text-gray-600 cursor-pointer">
        <%= f.check_box :remember_me, class: "h-4 w-4 rounded border-gray-300 text-preness-500 focus:ring-preness-500" %>
        <span>ログイン状態を保持する</span>
      </label>
    <% end %>

    <%= f.submit "ログイン", class: "w-full rounded-full bg-preness-500 px-4 py-4 text-sm font-bold text-white transition hover:opacity-90 shadow-sm" %>
  <% end %>

  <%= render "devise/shared/links" %>
<% end %>
