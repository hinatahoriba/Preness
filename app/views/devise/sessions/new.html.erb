<%= render "devise/shared/auth_shell", title: "ログイン", subtitle: "登録済みのメールアドレスとパスワードでログインします。" do %>
  <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-5" }) do |f| %>
    <div>
      <%= f.label :email, "メールアドレス", class: "text-sm font-medium text-slate-700" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "mt-1 w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-slate-900 placeholder-slate-400 outline-none ring-0 transition focus:border-orange-400 focus:ring-2 focus:ring-orange-300/40" %>
    </div>

    <div>
      <%= f.label :password, "パスワード", class: "text-sm font-medium text-slate-700" %>
      <%= f.password_field :password, autocomplete: "current-password", class: "mt-1 w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-slate-900 placeholder-slate-400 outline-none ring-0 transition focus:border-orange-400 focus:ring-2 focus:ring-orange-300/40" %>
    </div>

    <% if devise_mapping.rememberable? %>
      <label class="flex items-center gap-3 text-sm text-slate-600">
        <%= f.check_box :remember_me, class: "h-4 w-4 rounded border-slate-300 bg-white text-orange-500 focus:ring-orange-500" %>
        <span>ログイン状態を保持する</span>
      </label>
    <% end %>

    <%= f.submit "ログイン", class: "inline-flex w-full items-center justify-center rounded-xl bg-orange-500 px-4 py-3 text-sm font-semibold text-white transition hover:bg-orange-600" %>
  <% end %>

  <%= render "devise/shared/links" %>
<% end %>
