<%= render "devise/shared/auth_shell", title: "新しいパスワードを設定", subtitle: "再設定リンク経由で新しいパスワードを保存します。" do %>
  <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put, class: "space-y-5" }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>
    <%= f.hidden_field :reset_password_token %>

    <div>
      <div class="flex items-baseline justify-between">
        <%= f.label :password, "新しいパスワード", class: "text-sm font-medium text-slate-700" %>
        <% if @minimum_password_length %>
          <span class="text-xs text-slate-400">最低<%= @minimum_password_length %>文字</span>
        <% end %>
      </div>
      <%= f.password_field :password, autofocus: true, autocomplete: "new-password", class: "mt-1 w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-slate-900 placeholder-slate-400 outline-none ring-0 transition focus:border-preness-400 focus:ring-2 focus:ring-preness-300/40" %>
    </div>

    <div>
      <%= f.label :password_confirmation, "新しいパスワード（確認）", class: "text-sm font-medium text-slate-700" %>
      <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "mt-1 w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-slate-900 placeholder-slate-400 outline-none ring-0 transition focus:border-preness-400 focus:ring-2 focus:ring-preness-300/40" %>
    </div>

    <%= f.submit "パスワードを更新", class: "inline-flex w-full items-center justify-center rounded-xl bg-preness-500 px-4 py-3 text-sm font-semibold text-white transition hover:bg-preness-600" %>
  <% end %>

  <%= render "devise/shared/links" %>
<% end %>
