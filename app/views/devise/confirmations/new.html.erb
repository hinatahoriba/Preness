<%= render "devise/shared/auth_shell", title: "確認メールの再送", subtitle: "認証リンク付きメールを再送します。" do %>
  <%= form_for(resource, as: resource_name, url: confirmation_path(resource_name), html: { method: :post, class: "space-y-5" }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div>
      <%= f.label :email, "メールアドレス", class: "text-sm font-medium text-slate-700" %>
      <%= f.email_field :email,
          autofocus: true,
          autocomplete: "email",
          value: (resource.pending_reconfirmation? ? resource.unconfirmed_email : resource.email),
          class: "mt-1 w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-slate-900 placeholder-slate-400 outline-none ring-0 transition focus:border-orange-400 focus:ring-2 focus:ring-orange-300/40" %>
    </div>

    <%= f.submit "確認メールを再送", class: "inline-flex w-full items-center justify-center rounded-xl bg-orange-500 px-4 py-3 text-sm font-semibold text-white transition hover:bg-orange-600" %>
  <% end %>

  <%= render "devise/shared/links" %>
<% end %>
